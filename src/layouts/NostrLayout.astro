---
import NostrHeader from "../components/NostrHeader.astro";
import NostrFooter from "../components/NostrFooter.astro";
import AiTranslationNotice from "../components/AiTranslationNotice.astro";
import "../styles/global.css";
import { UMAMI_WEBSITE_ID } from "../site.config";
import {
	getLangFromPath,
	daKeyForPath,
	DA_TO_EN,
	EN_LIVE,
} from "../i18n/routes";

interface Props {
	title: string;
	description: string;
	ogImage?: string;
	/** default `website`; brug `article` til blogindlæg */
	ogType?: string;
	ogImageWidth?: string;
	ogImageHeight?: string;
	articlePublishedTime?: string;
	articleModifiedTime?: string;
	/** fx "noindex, nofollow" til testsider */
	robots?: string;
	/** Ekstra JSON-LD (fx BlogPosting) — serialiseres til eget script-tag */
	jsonLdArticle?: Record<string, unknown>;
}

const {
	title,
	description,
	ogImage = "/shaka.png",
	ogType = "website",
	ogImageWidth,
	ogImageHeight,
	articlePublishedTime,
	articleModifiedTime,
	robots,
	jsonLdArticle,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

// --- i18n: language + hreflang alternates (registry-driven, gated by EN_LIVE) ---
const lang = getLangFromPath(Astro.url.pathname);
const ogLocale = lang === "en" ? "en_US" : "da_DK";

// Build absolute alternate URLs matching Astro's trailing-slash convention.
const withSlash = (p: string) => (p.endsWith("/") ? p : `${p}/`);
const absUrl = (p: string) => new URL(withSlash(p), Astro.site).href;

const daKey = daKeyForPath(Astro.url.pathname);
const enPath = daKey != null ? DA_TO_EN[daKey] : undefined;
const alternates =
	daKey != null && enPath != null
		? {
				da: absUrl(daKey),
				// Only advertise the English alternate once that page is actually live,
				// so Danish-only pages never point at a 404.
				en: EN_LIVE.has(enPath) ? absUrl(enPath) : null,
				xDefault: absUrl(daKey), // x-default → Danish (canonical original)
			}
		: null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#2C2A3D" />
    {robots && <meta name="robots" content={robots} />}

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates (only emitted for registry pages; x-default → Danish) -->
    {alternates && (
      <>
        <link rel="alternate" hreflang="da" href={alternates.da} />
        {alternates.en && (
          <link rel="alternate" hreflang="en" href={alternates.en} />
        )}
        <link rel="alternate" hreflang="x-default" href={alternates.xDefault} />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
    {ogImageHeight && <meta property="og:image:height" content={ogImageHeight} />}
    <meta property="og:locale" content={ogLocale} />
    {articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" href="/NOSTRDK_favicon.png" type="image/png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts (preconnect før stylesheet) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    {lang === "da" && (
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Nostr.dk",
        "url": "https://nostr.dk",
        "description": "Dansk ressource om Nostr-protokollen – den censurresistente, decentraliserede protokol for sociale medier og meget mere.",
        "inLanguage": "da-DK",
        "publisher": {
          "@type": "Organization",
          "name": "Nostr.dk",
          "url": "https://nostr.dk",
          "email": "nostr@nostr.dk"
        }
      }
    </script>
    )}
    {lang === "en" && (
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Nostr.dk",
        "url": "https://nostr.dk",
        "description": "English resource about the Nostr protocol – the censorship-resistant, decentralized protocol for social media and much more.",
        "inLanguage": "en",
        "publisher": {
          "@type": "Organization",
          "name": "Nostr.dk",
          "url": "https://nostr.dk",
          "email": "nostr@nostr.dk"
        }
      }
    </script>
    )}
    {jsonLdArticle && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />
    )}

    <!-- Umami Analytics -->
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id={UMAMI_WEBSITE_ID}
    />
  </head>

  <body>
    {lang === "en" && <AiTranslationNotice />}
    <NostrHeader />
    <main class="container">
      <slot />
    </main>
    <NostrFooter />
    <slot name="after-footer" />
  </body>
</html>
