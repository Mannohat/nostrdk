---
import NostrLayout from "../layouts/NostrLayout.astro";
import { getCollection } from "astro:content";

// Get all published resources
const allResources = await getCollection("resources", ({ data }) => {
  return data.published === true;
});

const TYPE_LABELS: Record<string, string> = {
  client: "Klient",
  wallet: "Wallet",
  tool: "Værktøj",
  extension: "Udvidelse",
  relay: "Relay",
  marketplace: "Markedsplads",
  publishing: "Publicering",
  streaming: "Streaming",
  service: "Service",
};

const TYPE_LABELS_PLURAL: Record<string, string> = {
  client: "Klienter",
  wallet: "Wallets",
  tool: "Værktøjer",
  extension: "Udvidelser",
  relay: "Relays",
  marketplace: "Markedspladser",
  publishing: "Publicering",
  streaming: "Streaming",
  service: "Services",
};

function duckDuckGoFaviconUrl(rawUrl: string) {
  try {
    const href = new URL(rawUrl, Astro.site).href;
    const host = new URL(href).hostname;
    return `https://icons.duckduckgo.com/ip3/${host}.ico`;
  } catch {
    return undefined;
  }
}

function normalizeText(...parts: Array<string | undefined | null>) {
  return parts
    .filter(Boolean)
    .join(" ")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();
}

function inferType(resource: (typeof allResources)[number]) {
  // Explicit override wins (once you start populating markdown frontmatter)
  const explicit = resource.data.type;
  if (explicit && explicit !== "service") return explicit;

  const category = resource.data.category;
  if (category === "extensions") return "extension";
  if (category === "relays") return "relay";

  const text = normalizeText(
    resource.data.title,
    resource.data.description,
    resource.data.section,
    resource.data.url,
  );

  // Strong client signals (known clients + "client/klient")
  if (
    /\b(client|klient)\b/.test(text) ||
    /\b(damus|primal|snort|coracle|iris)\b/.test(text)
  ) {
    return "client";
  }

  if (/\b(wallet|lightning wallet|nwc|wallet connect|lnurl)\b/.test(text)) return "wallet";
  if (/\b(marketplace|markedsplads|market)\b/.test(text)) return "marketplace";
  if (/\b(stream|streaming|video|music|podcast)\b/.test(text)) return "streaming";
  if (/\b(publicer|publicering|publish|publishing|blog|artikler|news)\b/.test(text)) return "publishing";
  if (/\b(tool|værktøj|search|søg|stats|directory|discover|discovery)\b/.test(text)) return "tool";

  // Fallback
  return explicit || "service";
}

const availableTypes = Array.from(
  new Set(allResources.map((r) => inferType(r)).filter(Boolean)),
).sort((a, b) =>
  (TYPE_LABELS_PLURAL[a] ?? TYPE_LABELS[a] ?? a).localeCompare(
    TYPE_LABELS_PLURAL[b] ?? TYPE_LABELS[b] ?? b,
    "da",
  ),
);

const TYPE_SECTION_META: Record<string, { title: string; description?: string }> = {
  client: { title: "Klienter", description: "Apps til at bruge Nostr (social, notes, feeds osv.)." },
  wallet: { title: "Wallets", description: "Lightning/NWC wallets og betaling." },
  tool: { title: "Værktøjer", description: "Alt det praktiske til Nostr-økosystemet." },
  extension: { title: "Udvidelser", description: "Browser-udvidelser til nøgler og signering." },
  relay: { title: "Relays", description: "Relays og relaterede services." },
  marketplace: { title: "Markedspladser" },
  publishing: { title: "Publicering" },
  streaming: { title: "Streaming" },
  service: { title: "Services" },
};

const resourcesByType = availableTypes.reduce((acc, t) => {
  acc[t] = allResources
    .filter((r) => inferType(r) === t)
    .sort((a, b) => {
      const ao = Number.isFinite(a.data.order) ? a.data.order : 9999;
      const bo = Number.isFinite(b.data.order) ? b.data.order : 9999;
      if (ao !== bo) return ao - bo;
      return a.data.title.localeCompare(b.data.title, "da");
    });
  return acc;
}, {} as Record<string, typeof allResources>);

const appsItemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Apps & Tjenester",
  itemListOrder: "http://schema.org/ItemListOrderAscending",
  itemListElement: allResources.map((r, idx) => {
    const url = (() => {
      const raw = r.data.url;
      try {
        return new URL(raw, Astro.site).href;
      } catch {
        return raw;
      }
    })();

    return {
      "@type": "ListItem",
      position: idx + 1,
      name: r.data.title,
      url,
      description: r.data.description,
    };
  }),
};
---

<NostrLayout
  title="Apps & Tjenester | Nostr.dk"
  description="Oversigt over decentraliserede apps og tjenester bygget på Nostr – alternativer til YouTube, Twitter, Facebook og meget mere."
  jsonLdArticle={appsItemListLd}
>

  <div class="page-header">
    <h1>Apps & Tjenester</h1>
    <p>
      Stort set alle de services og virksomheder som f.eks. Youtube, Google,
      Facebook, Twitter osv. har dine data og kan lukke dig ude fra din
      konto. Nostr giver dig mulighed for at eje din egen data, sikrer dig
      adgang og beholde dine følgere på tværs af Nostr-baserede services.
    </p>
  </div>

  <!-- Search Bar with Subtle Contribute Link -->
  <div class="search-container">
    <label for="search-input" class="visually-hidden">Søg efter apps og tjenester</label>
    <input
      type="text"
      id="search-input"
      placeholder="🔍 Søg efter apps og tjenester..."
      class="search-input"
      autocomplete="off"
    />
  </div>

  <!-- Filters -->
  <div class="filters" aria-label="Filtre">
    <div class="filters-bar">
      <label class="filters-label" for="type-select">Type</label>
      <select id="type-select" class="filters-select">
        <option value="">Alle</option>
        {availableTypes.map((t) => (
          <option value={t}>{TYPE_LABELS_PLURAL[t] ?? TYPE_LABELS[t] ?? t}</option>
        ))}
      </select>

      <button type="button" class="filters-clear" id="clear-filters" style="display:none;">
        Nulstil
      </button>
    </div>

    <!-- Subtle Contribute Link – åbner nu modal i stedet for GitHub -->
    <div class="contribute-link">
      <p>
        Mangler der noget? <button type="button" class="link-button" id="open-modal-subtle" data-umami-event="apps-suggest-open-subtle">Foreslå App / Tjeneste →</button>
      </p>
    </div>
  </div>

  <!-- Resources by Category -->
  {
    availableTypes.map((typeKey) => {
      const resources = resourcesByType[typeKey];
      if (!resources || resources.length === 0) return null;
      const meta = TYPE_SECTION_META[typeKey] ?? { title: TYPE_LABELS[typeKey] ?? typeKey };

      return (
        <section class="resource-section" data-type={typeKey}>
          <h2 class="section-title">{meta.title}</h2>
          {meta.description && <p class="section-description">{meta.description}</p>}

          <div class="resource-grid">
            {resources.map((resource) => (
              <div
                class="resource-card"
                data-search-text={`${resource.data.title} ${resource.data.description} ${resource.data.section}`.toLowerCase()}
                data-type={inferType(resource)}
              >
                <div class="resource-title-row">
                  {duckDuckGoFaviconUrl(resource.data.url) && (
                    <img
                      class="resource-favicon"
                      src={duckDuckGoFaviconUrl(resource.data.url)}
                      alt={`${resource.data.title} ikon`}
                      width="24"
                      height="24"
                      loading="lazy"
                      decoding="async"
                      referrerpolicy="no-referrer"
                      onerror="this.remove()"
                    />
                  )}
                  <h3>{resource.data.title}</h3>
                </div>
                <p>{resource.data.description}</p>
                <a
                  href={resource.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="resource-link"
                  data-umami-event="apps-resource-outbound"
                >
                  Besøg {resource.data.title} →
                </a>
              </div>
            ))}
          </div>
        </section>
      );
    })
  }

  <!-- No results message (hidden by default) -->
  <div id="no-results" class="no-results" style="display: none;">
    <h2>Ingen resultater fundet</h2>
    <p>Prøv at søge efter noget andet.</p>
  </div>

  <!-- CTA Section – primær knap åbner modal -->
  <section class="cta-section">
    <h2>Bidrag til Nostr.dk</h2>
    <p>
      Hjælp os med at gøre listen bedre eller udforsk mere indhold om Nostr
    </p>
    <div class="cta-buttons">
      <button type="button" class="cta-button primary" id="open-modal-cta" data-umami-event="apps-suggest-open-cta">
        ➕ Foreslå App / Tjeneste
      </button>
      <a href="/podcasts" class="cta-button secondary">Se Podcasts →</a>
      <a href="/" class="cta-button secondary">Gå til Forsiden →</a>
    </div>
  </section>

  <div slot="after-footer">
<!-- =====================================================
     MODAL – Foreslå ressource
     ===================================================== -->
<div id="suggest-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal-box">
    <!-- Luk-knap -->
    <button class="modal-close" id="close-modal" aria-label="Luk">&times;</button>

    <!-- Header -->
    <div class="modal-header">
      <div class="modal-icon">➕</div>
      <h2 id="modal-title">Foreslå en ressource</h2>
      <p>Kender du en app eller tjeneste som mangler? Send et forslag – vi gennemgår det hurtigst muligt.</p>
    </div>

    <!-- Form -->
    <form class="modal-form" id="modal-form-container" novalidate>
      <div class="form-grid">
        <div class="form-group">
          <label for="field-name">Navn <span class="required">*</span></label>
        <input type="text" id="field-name" placeholder="f.eks. Damus, Primal, Coracle" maxlength="80" autocomplete="off" required aria-describedby="error-name" />
          <span class="field-error" id="error-name" aria-live="polite"></span>
        </div>

        <div class="form-group">
          <label for="field-url">Link (URL) <span class="required">*</span></label>
          <input type="url" id="field-url" placeholder="https://…" maxlength="200" inputmode="url" autocomplete="off" required aria-describedby="error-url" />
          <span class="field-error" id="error-url" aria-live="polite"></span>
        </div>

        <div class="form-group">
          <label for="field-type">Type <span class="required">*</span></label>
          <select id="field-type" required aria-describedby="error-type">
            <option value="">Vælg type</option>
            <option value="client">Klient</option>
            <option value="wallet">Wallet</option>
            <option value="tool">Værktøj</option>
            <option value="extension">Udvidelse</option>
            <option value="relay">Relay</option>
            <option value="marketplace">Markedsplads</option>
            <option value="publishing">Publicering</option>
            <option value="streaming">Streaming</option>
            <option value="service">Service</option>
          </select>
          <span class="field-error" id="error-type" aria-live="polite"></span>
        </div>

        <div class="form-group form-group--full">
          <label for="field-description">Kort beskrivelse <span class="required">*</span></label>
          <textarea id="field-description" placeholder="Hvad gør appen/tjenesten? (max 300 tegn)" maxlength="300" rows="3" required aria-describedby="error-description"></textarea>
          <div class="char-counter"><span id="char-count">0</span> / 300</div>
          <span class="field-error" id="error-description" aria-live="polite"></span>
        </div>
      </div>

      <button type="submit" class="submit-button" id="submit-suggestion" data-umami-event="apps-suggest-submit">
        <span id="submit-text">Send forslag</span>
        <span id="submit-spinner" class="spinner" style="display:none;"></span>
      </button>
    </form>

    <!-- Succesbesked (skjult som standard) -->
    <div class="modal-success" id="modal-success" style="display:none;">
      <div class="success-icon">✅</div>
      <h3>Tak for dit forslag!</h3>
      <p>Dit forslag er nu sendt og vil blive gennemgået hurtigst muligt.</p>
      <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;">
        <button class="cta-button primary" id="suggest-another">Foreslå en ny →</button>
        <button class="cta-button secondary" id="close-success">Luk</button>
      </div>
    </div>

    <!-- Fejlbesked (skjult som standard) -->
    <div class="modal-error-banner" id="modal-error-banner" style="display:none;" role="alert" aria-live="assertive">
      <span id="modal-error-text">Der skete en fejl. Prøv igen.</span>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    let lastFocusedBeforeModal = null;

    // ── Søgefunktion ──────────────────────────────────────
    const searchInput = document.getElementById("search-input");
    const resourceCards = document.querySelectorAll(".resource-card");
    const resourceSections = document.querySelectorAll(".resource-section");
    const noResults = document.getElementById("no-results");
    const typeSelect = document.getElementById("type-select");
    const clearFiltersBtn = document.getElementById("clear-filters");

    let activeType = "";

    // Restore state from URL (deep links like /apps?type=client&q=primal)
    try {
      const params = new URLSearchParams(window.location.search || "");
      const t = (params.get("type") || "").trim();
      const q = (params.get("q") || "").trim();
      if (t && typeSelect) {
        typeSelect.value = t;
        activeType = t;
      }
      if (q && searchInput) {
        searchInput.value = q;
      }
    } catch {}

    function syncUrl() {
      try {
        const url = new URL(window.location.href);
        const q = (searchInput?.value || "").trim();
        if (activeType) url.searchParams.set("type", activeType);
        else url.searchParams.delete("type");
        if (q) url.searchParams.set("q", q);
        else url.searchParams.delete("q");
        // Keep it tidy
        if (!url.searchParams.toString()) url.search = "";
        window.history.replaceState({}, "", url.toString());
      } catch {}
    }

    function updateClearVisible() {
      const hasAny = Boolean(activeType) || Boolean((searchInput?.value || "").trim());
      if (clearFiltersBtn) clearFiltersBtn.style.display = hasAny ? "inline-flex" : "none";
    }

    function applyFilters() {
      const searchTerm = (searchInput?.value || "").toLowerCase().trim();
      let visibleCount = 0;

      resourceCards.forEach(function (card) {
        const searchText = card.getAttribute("data-search-text") || "";
        const matchesSearch = !searchTerm || searchText.includes(searchTerm);

        const type = card.getAttribute("data-type") || "";
        const matchesType = !activeType || type === activeType;

        const show = matchesSearch && matchesType;
        card.classList.toggle("hidden", !show);
        if (show) visibleCount++;
      });

      resourceSections.forEach(function (section) {
        const cardsInSection = section.querySelectorAll(".resource-card");
        const hasVisible = Array.from(cardsInSection).some(
          (c) => !c.classList.contains("hidden")
        );
        section.classList.toggle("hidden", !hasVisible);
      });

      if (noResults) {
        noResults.style.display = visibleCount === 0 ? "block" : "none";
      }

      syncUrl();
      updateClearVisible();
    }

    if (typeSelect) {
      typeSelect.addEventListener("change", () => {
        activeType = typeSelect.value || "";
        applyFilters();
      });
    }

    if (clearFiltersBtn) {
      clearFiltersBtn.addEventListener("click", () => {
        activeType = "";
        if (searchInput) searchInput.value = "";
        if (typeSelect) typeSelect.value = "";
        applyFilters();
      });
    }

    if (searchInput) {
      let qT;
      searchInput.addEventListener("input", function () {
        // slight debounce for typing
        clearTimeout(qT);
        qT = setTimeout(applyFilters, 80);
      });
    }

    // Apply once on load after restoring URL state
    applyFilters();

    // ── Modal: åbn / luk ─────────────────────────────────
    const modal = document.getElementById("suggest-modal");
    const openButtons = [
      document.getElementById("open-modal-cta"),
      document.getElementById("open-modal-subtle"),
    ];
    const closeBtn = document.getElementById("close-modal");
    const closeSuccess = document.getElementById("close-success");
    const formEl = document.getElementById("modal-form-container");
    const submitBtn = document.getElementById("submit-suggestion");

    const errorIds = ["error-name", "error-url", "error-description", "error-type"];
    const fieldIds = ["field-name", "field-url", "field-type", "field-description"];

    function setFieldError(fieldId, errorId, message) {
      const field = document.getElementById(fieldId);
      const err = document.getElementById(errorId);
      if (err) err.textContent = message || "";
      if (field && field instanceof HTMLElement) {
        if (message) field.setAttribute("aria-invalid", "true");
        else field.removeAttribute("aria-invalid");
      }
    }

    function resetSuggestModalState() {
      // Ensure form view is active
      const success = document.getElementById("modal-success");
      const banner = document.getElementById("modal-error-banner");
      if (success) success.style.display = "none";
      if (banner) banner.style.display = "none";
      if (formEl) formEl.style.display = "flex";

      // Clear errors / aria-invalid
      errorIds.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.textContent = "";
      });
      fieldIds.forEach((id) => {
        const el = document.getElementById(id);
        if (el && el instanceof HTMLElement) el.removeAttribute("aria-invalid");
      });
    }

    function openModal() {
      lastFocusedBeforeModal = document.activeElement;
      modal.setAttribute("aria-hidden", "false");
      modal.classList.add("is-open");
      document.body.style.overflow = "hidden";
      resetSuggestModalState();
      setTimeout(() => document.getElementById("field-name").focus(), 100);
    }

    function closeModal() {
      modal.setAttribute("aria-hidden", "true");
      modal.classList.remove("is-open");
      document.body.style.overflow = "";
      if (lastFocusedBeforeModal instanceof HTMLElement) {
        lastFocusedBeforeModal.focus();
      }
    }

    function trapModalFocus(e) {
      if (!modal.classList.contains("is-open") || e.key !== "Tab") return;
      const focusable = modal.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])',
      );
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    openButtons.forEach((btn) => btn && btn.addEventListener("click", openModal));
    closeBtn && closeBtn.addEventListener("click", closeModal);
    closeSuccess && closeSuccess.addEventListener("click", closeModal);

    // Nulstil formularen og vis den igen
    const suggestAnother = document.getElementById("suggest-another");
    suggestAnother && suggestAnother.addEventListener("click", function () {
      document.getElementById("field-name").value = "";
      document.getElementById("field-url").value = "";
      document.getElementById("field-type").value = "";
      document.getElementById("field-description").value = "";
      charCount.textContent = "0";
      ["error-name", "error-url", "error-description"].forEach(
        (id) => (document.getElementById(id).textContent = "")
      );
      document.getElementById("error-type").textContent = "";
      document.getElementById("modal-error-banner").style.display = "none";
      document.getElementById("modal-success").style.display = "none";
      document.getElementById("modal-form-container").style.display = "flex";
      document.getElementById("field-name").focus();
    });

    // Luk ved klik på backdrop
    modal.addEventListener("click", function (e) {
      if (e.target === modal) closeModal();
    });

    // Luk med Escape
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && modal.classList.contains("is-open")) closeModal();
      trapModalFocus(e);
    });

    // ── Tegntæller ────────────────────────────────────────
    const descField = document.getElementById("field-description");
    const charCount = document.getElementById("char-count");
    descField && descField.addEventListener("input", function () {
      charCount.textContent = this.value.length;
    });

    formEl && formEl.addEventListener("submit", async function (e) {
      e.preventDefault();
      // Ryd tidligere fejl
      resetSuggestModalState();

      const name = document.getElementById("field-name").value.trim();
      const url = document.getElementById("field-url").value.trim();
      const description = document.getElementById("field-description").value.trim();
      const type = document.getElementById("field-type").value;
      // Backend derives category; we don't ask for more.

      // Klientside-validering
      let valid = true;
      if (!name) {
        setFieldError("field-name", "error-name", "Navn er påkrævet");
        valid = false;
      }
      if (!url) {
        setFieldError("field-url", "error-url", "URL er påkrævet");
        valid = false;
      } else {
        try { new URL(url); } catch {
          setFieldError("field-url", "error-url", "Indtast en gyldig URL (husk https://)");
          valid = false;
        }
      }
      if (!description) {
        setFieldError("field-description", "error-description", "Beskrivelse er påkrævet");
        valid = false;
      }
      if (!type) {
        setFieldError("field-type", "error-type", "Type er påkrævet");
        valid = false;
      }
      if (!valid) {
        const firstInvalid = formEl.querySelector('[aria-invalid="true"]');
        if (firstInvalid && firstInvalid instanceof HTMLElement) firstInvalid.focus();
        return;
      }

      // Vis spinner
      document.getElementById("submit-text").style.display = "none";
      document.getElementById("submit-spinner").style.display = "inline-block";
      submitBtn.disabled = true;

      try {
        const res = await fetch("/.netlify/functions/suggest-resource", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name, url, description, type }),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          window.umami?.track("apps-suggest-success");
          document.getElementById("modal-form-container").style.display = "none";
          document.getElementById("modal-success").style.display = "flex";
        } else {
          throw new Error(data.error || "Ukendt fejl");
        }
      } catch (err) {
        window.umami?.track("apps-suggest-failure");
        const banner = document.getElementById("modal-error-banner");
        document.getElementById("modal-error-text").textContent =
          err.message || "Der skete en fejl – prøv igen.";
        banner.style.display = "block";
      } finally {
        document.getElementById("submit-text").style.display = "inline";
        document.getElementById("submit-spinner").style.display = "none";
        submitBtn.disabled = false;
      }
    });
  });
</script>
  </div>
</NostrLayout>

<style>
  /* ── Generelle utilities ── */
  .hidden {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    overflow: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* ── Søgefelt ── */
  .search-container {
    max-width: 1040px;
    margin: 20px auto 16px;
    padding: 0 20px;
  }

  .search-input {
    width: 100%;
    padding: 20px 28px;
    font-size: 1.15rem;
    font-weight: 500;
    border: 3px solid rgba(160, 132, 202, 0.4);
    border-radius: 50px;
    background: linear-gradient(135deg, rgba(108,79,150,0.15), rgba(55,26,118,0.15));
    color: #fff;
    transition: all 0.3s;
    text-align: center;
  }
  .search-input:focus {
    outline: none;
    border-color: #a084ca;
    background: linear-gradient(135deg, rgba(108,79,150,0.25), rgba(55,26,118,0.25));
    box-shadow: 0 0 30px rgba(160,132,202,0.4);
