---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Profiler verificeret med @nostr.dk | nostr.dk"
  description="Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse."
>
  <div class="page-header">
    <h1>Profiler verificeret med @nostr.dk</h1>
    <p>Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse.</p>
  </div>

  <div class="profiler-wrap">
    <div id="loading" class="loading-msg">Henter profiler…</div>
    <div id="grid" class="profiler-grid"></div>
  </div>

</NostrLayout>

<style is:global>
  .profiler-wrap {
    padding: 0 0 80px;
  }

  .loading-msg {
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    padding: 60px 0;
  }

  .profiler-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 28px 16px;
    margin-top: 10px;
  }

  .profil-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    padding: 8px;
    border-radius: 12px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .profil-card:hover {
    transform: translateY(-4px);
    background: rgba(108, 79, 150, 0.15);
  }

  .profil-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 79, 150, 0.6);
    display: block;
    margin-bottom: 10px;
  }

  .profil-avatar-placeholder {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    border: 2px solid rgba(108, 79, 150, 0.3);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.2), rgba(55, 26, 118, 0.2));
    display: block;
    margin-bottom: 10px;
    flex-shrink: 0;
  }

  .profil-nip05 {
    font-size: 0.7rem;
    line-height: 1.3;
    word-break: break-all;
  }

  .profil-name {
    color: rgba(200, 180, 230, 0.85);
    font-weight: 500;
  }

  .profil-domain {
    color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .profiler-grid {
      grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
      gap: 20px 10px;
    }

    .profil-avatar,
    .profil-avatar-placeholder {
      width: 68px;
      height: 68px;
    }
  }
</style>

<script>
  const NOSTR_JSON_URL = "https://nostr.dk/.well-known/nostr.json";
  const RELAYS = [
    "wss://relay.primal.net",
    "wss://relay.nostr.band",
    "wss://nos.lol",
  ];

  const grid = document.getElementById("grid")!;
  const loading = document.getElementById("loading")!;
  const cards: Record<string, HTMLElement> = {};
  const resolved = new Set<string>();

  async function init() {
    let names: Record<string, string> = {};
    try {
      const res = await fetch(NOSTR_JSON_URL);
      const data = await res.json();
      names = data.names || {};
    } catch {
      loading.textContent = "Kunne ikke hente brugerliste — prøv igen.";
      return;
    }

    const entries = Object.entries(names).sort(() => Math.random() - 0.5);
    if (entries.length === 0) {
      loading.textContent = "Ingen profiler endnu.";
      return;
    }

    loading.style.display = "none";

    for (const [name, pubkey] of entries) {
      const card = document.createElement("a");
      card.className = "profil-card";
      card.href = `https://primal.net/p/${pubkey}`;
      card.target = "_blank";
      card.rel = "noopener noreferrer";

      const placeholder = document.createElement("div");
      placeholder.className = "profil-avatar-placeholder";

      const nip05 = document.createElement("div");
      nip05.className = "profil-nip05";
      nip05.innerHTML = `<span class="profil-name">${name}</span><span class="profil-domain">@nostr.dk</span>`;

      card.appendChild(placeholder);
      card.appendChild(nip05);
      grid.appendChild(card);
      cards[pubkey] = card;
    }

    const pubkeys = entries.map(([, pubkey]) => pubkey);
    RELAYS.forEach(relay => connectRelay(relay, pubkeys));
  }

  function applyProfile(pubkey: string, picture: string) {
    if (resolved.has(pubkey)) return;
    const card = cards[pubkey];
    if (!card) return;
    const placeholder = card.querySelector(".profil-avatar-placeholder");
    if (!placeholder) return;

    const img = document.createElement("img");
    img.className = "profil-avatar";
    img.alt = pubkey.slice(0, 8);
    img.src = picture;
    img.onerror = () => {};
    placeholder.replaceWith(img);
    resolved.add(pubkey);
  }

  function connectRelay(url: string, pubkeys: string[]) {
    try {
      const ws = new WebSocket(url);
      const subId = "p" + Math.random().toString(36).slice(2, 8);

      ws.onopen = () => {
        ws.send(JSON.stringify([
          "REQ", subId,
          { kinds: [0], authors: pubkeys, limit: pubkeys.length }
        ]));
      };

      ws.onmessage = (e) => {
        try {
          const msg = JSON.parse(e.data);
          if (msg[0] === "EOSE") { ws.close(); return; }
          if (msg[0] !== "EVENT" || msg[2]?.kind !== 0) return;
          const profile = JSON.parse(msg[2].content);
          if (profile?.picture) {
            applyProfile(msg[2].pubkey, profile.picture);
          }
        } catch {}
      };

      ws.onerror = () => {};
    } catch {}
  }

  init();
</script>