---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Profiler verificeret med @nostr.dk | nostr.dk"
  description="Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse."
>
  <div class="page-header">
    <h1>Profiler verificeret med @nostr.dk</h1>
    <p>Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse.</p>
  </div>

  <div class="profiler-wrap">
    <div id="loading" class="loading-msg">Henter profiler…</div>
    <div id="grid" class="profiler-grid"></div>
  </div>

</NostrLayout>

<style>
  .profiler-wrap {
    padding: 0 0 80px;
  }

  .loading-msg {
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    padding: 60px 0;
  }

  .profiler-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 24px;
    margin-top: 10px;
  }

  .profil-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    padding: 8px;
    border-radius: 12px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .profil-card:hover {
    transform: translateY(-4px);
    background: rgba(108, 79, 150, 0.15);
  }

  .avatar-wrap {
    position: relative;
    width: 96px;
    height: 96px;
    margin-bottom: 12px;
  }

  .profil-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 79, 150, 0.6);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.4), rgba(55, 26, 118, 0.4));
    display: block;
  }

  .profil-avatar-placeholder {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid rgba(108, 79, 150, 0.6);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.4), rgba(55, 26, 118, 0.4));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 700;
    letter-spacing: -1px;
  }

  .profil-name {
    font-size: 0.72rem;
    font-weight: 500;
    color: rgba(160, 132, 202, 0.9);
    line-height: 1.3;
    word-break: break-all;
    margin-top: 10px;
  }

  .profil-domain {
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.2);
    margin-top: 1px;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .profiler-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 16px;
    }

    .avatar-wrap,
    .profil-avatar,
    .profil-avatar-placeholder {
      width: 72px;
      height: 72px;
    }

    .profil-avatar-placeholder {
      font-size: 1.6rem;
    }
  }
</style>

<script>
  const RELAYS = [
    "wss://nos.lol",
    "wss://relay.nostr.band",
    "wss://relay.primal.net",
  ];
  const NOSTR_JSON_URL = "https://nostr.dk/.well-known/nostr.json";

  const grid = document.getElementById("grid")!;
  const loading = document.getElementById("loading")!;

  const cards: Record<string, HTMLAnchorElement> = {};
  const resolved = new Set<string>();

  async function init() {
    let names: Record<string, string> = {};
    try {
      const res = await fetch(NOSTR_JSON_URL);
      const data = await res.json();
      names = data.names || {};
    } catch {
      loading.textContent = "Kunne ikke hente brugerliste — prøv igen.";
      return;
    }

    const entries = Object.entries(names);
    if (entries.length === 0) {
      loading.textContent = "Ingen profiler endnu.";
      return;
    }

    loading.style.display = "none";

    for (const [name, pubkey] of entries) {
      const card = document.createElement("a");
      card.className = "profil-card";
      card.href = `https://primal.net/p/${pubkey}`;
      card.target = "_blank";
      card.rel = "noopener noreferrer";

      card.innerHTML = `
        <div class="avatar-wrap">
          <div class="profil-avatar-placeholder"></div>
        </div>
        <span class="profil-name">${name}</span>
        <span class="profil-domain">@nostr.dk</span>
      `;

      grid.appendChild(card);
      cards[pubkey] = card;
    }

    const pubkeys = entries.map(([, pubkey]) => pubkey);
    for (const relay of RELAYS) {
      fetchProfiles(pubkeys, relay);
    }
  }

  function handleEvent(msg: any) {
    try {
      if (msg[0] !== "EVENT" || msg[2].kind !== 0) return;
      const pubkey = msg[2].pubkey;
      if (resolved.has(pubkey)) return;

      const profile = JSON.parse(msg[2].content);
      const card = cards[pubkey];
      if (!card || !profile.picture) return;

      const placeholder = card.querySelector(".profil-avatar-placeholder");
      if (!placeholder) return;

      const img = document.createElement("img");
      img.className = "profil-avatar";
      img.alt = profile.display_name || profile.name || "";
      img.loading = "lazy";
      img.onerror = () => {};
      img.src = profile.picture;
      placeholder.replaceWith(img);
      resolved.add(pubkey);
    } catch {}
  }

  function fetchProfiles(pubkeys: string[], relayUrl: string) {
    try {
      const ws = new WebSocket(relayUrl);
      ws.onopen = () => {
        ws.send(JSON.stringify(["REQ", "profiles", { kinds: [0], authors: pubkeys }]));
      };
      ws.onmessage = (event) => {
        try {
          const msg = JSON.parse(event.data);
          if (msg[0] === "EOSE") { ws.close(); return; }
          handleEvent(msg);
        } catch {}
      };
      ws.onerror = () => {};
    } catch {}
  }

  init();
</script>