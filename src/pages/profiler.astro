---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Profiler verificeret med @nostr.dk | nostr.dk"
  description="Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse."
>
  <div class="page-header">
    <h1>Profiler verificeret med @nostr.dk</h1>
    <p>Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse.</p>
  </div>

  <div class="profiler-wrap">
    <div id="loading" class="loading-msg">Henter profiler…</div>
    <div id="grid" class="profiler-grid"></div>
  </div>

</NostrLayout>

<style is:global>
  .profiler-wrap {
    padding: 0 0 80px;
  }

  .loading-msg {
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    padding: 60px 0;
  }

  .profiler-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 20px;
    margin-top: 10px;
  }

  .profil-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    padding: 16px 8px 12px;
    border-radius: 12px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .profil-card:hover {
    transform: translateY(-4px);
    background: rgba(108, 79, 150, 0.2);
  }

  .profil-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 79, 150, 0.6);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.3), rgba(55, 26, 118, 0.3));
    display: block;
    margin-bottom: 10px;
  }

  .profil-avatar-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 2px solid rgba(108, 79, 150, 0.4);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.2), rgba(55, 26, 118, 0.2));
    display: block;
    margin-bottom: 10px;
    flex-shrink: 0;
  }

  .profil-nip05 {
    font-size: 0.72rem;
    line-height: 1.4;
    word-break: break-all;
  }

  .profil-name {
    font-weight: 500;
    color: rgba(200, 180, 230, 0.85);
  }

  .profil-domain {
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .profiler-grid {
      grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
      gap: 12px;
    }

    .profil-avatar,
    .profil-avatar-placeholder {
      width: 64px;
      height: 64px;
    }
  }
</style>

<script>
  const NOSTR_JSON_URL = "https://nostr.dk/.well-known/nostr.json";
  const PRIMAL_API = "https://api.primal.net/v1";

  const grid = document.getElementById("grid")!;
  const loading = document.getElementById("loading")!;

  async function init() {
    // Hent nostr.json
    let names: Record<string, string> = {};
    try {
      const res = await fetch(NOSTR_JSON_URL);
      const data = await res.json();
      names = data.names || {};
    } catch {
      loading.textContent = "Kunne ikke hente brugerliste — prøv igen.";
      return;
    }

    const entries = Object.entries(names).sort(() => Math.random() - 0.5);
    if (entries.length === 0) {
      loading.textContent = "Ingen profiler endnu.";
      return;
    }

    loading.style.display = "none";

    // Opret kort med placeholder cirkel
    const cards: Record<string, HTMLAnchorElement> = {};
    for (const [name, pubkey] of entries) {
      const card = document.createElement("a");
      card.className = "profil-card";
      card.href = `https://primal.net/p/${pubkey}`;
      card.target = "_blank";
      card.rel = "noopener noreferrer";

      const placeholder = document.createElement("div");
      placeholder.className = "profil-avatar-placeholder";

      const nip05Div = document.createElement("div");
      nip05Div.className = "profil-nip05";
      nip05Div.innerHTML = `<span class="profil-name">${name}</span><span class="profil-domain">@nostr.dk</span>`;

      card.appendChild(placeholder);
      card.appendChild(nip05Div);
      grid.appendChild(card);
      cards[pubkey] = card;
    }

    // Hent profiler fra Primal HTTP API
    const pubkeys = entries.map(([, pubkey]) => pubkey);
    try {
      const res = await fetch(PRIMAL_API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(["user_infos", { pubkeys }]),
      });
      const data = await res.json();

      for (const item of data) {
        if (!item?.pubkey || !item?.picture) continue;
        const card = cards[item.pubkey];
        if (!card) continue;

        const placeholder = card.querySelector(".profil-avatar-placeholder");
        if (!placeholder) continue;

        const img = document.createElement("img");
        img.className = "profil-avatar";
        img.alt = item.display_name || item.name || "";
        img.loading = "lazy";
        img.onerror = () => {};
        img.src = item.picture;
        placeholder.replaceWith(img);
      }
    } catch {
      // Profiler vises med placeholder ved fejl
    }
  }

  init();
</script>