---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Profiler verificeret med @nostr.dk | nostr.dk"
  description="Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse."
>
  <div class="page-header">
    <h1>Profiler verificeret med @nostr.dk</h1>
    <p>Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse.</p>
  </div>

  <div class="profiler-wrap">
    <div id="loading" class="loading-msg">Henter profiler…</div>
    <div id="grid" class="profiler-grid"></div>
  </div>

</NostrLayout>

<style>
  .profiler-wrap {
    padding: 0 0 80px;
  }

  .loading-msg {
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    padding: 60px 0;
  }

  .profiler-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 24px;
    margin-top: 10px;
  }

  .profil-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    padding: 8px;
    border-radius: 12px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .profil-card:hover {
    transform: translateY(-4px);
    background: rgba(108, 79, 150, 0.15);
  }

  .avatar-wrap {
    position: relative;
    width: 96px;
    height: 96px;
    margin-bottom: 12px;
  }

  .profil-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 79, 150, 0.6);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.4), rgba(55, 26, 118, 0.4));
    display: block;
  }

  .profil-avatar-placeholder {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid rgba(108, 79, 150, 0.6);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.4), rgba(55, 26, 118, 0.4));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 700;
    letter-spacing: -1px;
  }

  .profil-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
    word-break: break-all;
  }

  .profil-domain {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 1px;
  }

  @media (max-width: 768px) {
    .profiler-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 16px;
    }

    .avatar-wrap,
    .profil-avatar,
    .profil-avatar-placeholder {
      width: 72px;
      height: 72px;
    }

    .profil-avatar-placeholder {
      font-size: 1.6rem;
    }
  }
</style>

<script>
  const RELAY_URL = "wss://relay.damus.io";
  const NOSTR_JSON_URL = "https://nostr.dk/.well-known/nostr.json";

  const grid = document.getElementById("grid")!;
  const loading = document.getElementById("loading")!;

  const cards: Record<string, HTMLAnchorElement> = {};

  async function init() {
    let names: Record<string, string> = {};
    try {
      const res = await fetch(NOSTR_JSON_URL);
      const data = await res.json();
      names = data.names || {};
    } catch {
      loading.textContent = "Kunne ikke hente brugerliste — prøv igen.";
      return;
    }

    const entries = Object.entries(names);
    if (entries.length === 0) {
      loading.textContent = "Ingen profiler endnu.";
      return;
    }

    loading.style.display = "none";

    for (const [name, pubkey] of entries) {
      const card = document.createElement("a");
      card.className = "profil-card";
      card.href = `https://primal.net/p/${pubkey}`;
      card.target = "_blank";
      card.rel = "noopener noreferrer";

      // Initialer som placeholder
      const initials = name.slice(0, 2).toUpperCase();

      card.innerHTML = `
        <div class="avatar-wrap">
          <div class="profil-avatar-placeholder">${initials}</div>
        </div>
        <span class="profil-name">${name}</span>
        <span class="profil-domain">@nostr.dk</span>
      `;

      grid.appendChild(card);
      cards[pubkey] = card;
    }

    fetchProfiles(entries.map(([, pubkey]) => pubkey));
  }

  function fetchProfiles(pubkeys: string[]) {
    const ws = new WebSocket(RELAY_URL);

    ws.onopen = () => {
      ws.send(JSON.stringify([
        "REQ", "profiles",
        { kinds: [0], authors: pubkeys }
      ]));
    };

    ws.onmessage = (event) => {
      try {
        const msg = JSON.parse(event.data);
        if (msg[0] === "EOSE") { ws.close(); return; }
        if (msg[0] !== "EVENT" || msg[2].kind !== 0) return;

        const profile = JSON.parse(msg[2].content);
        const card = cards[msg[2].pubkey];
        if (!card || !profile.picture) return;

        const placeholder = card.querySelector(".profil-avatar-placeholder");
        if (!placeholder) return;

        const img = document.createElement("img");
        img.className = "profil-avatar";
        img.alt = profile.display_name || profile.name || "";
        img.loading = "lazy";
        img.onerror = () => { /* behold placeholder */ };
        img.src = profile.picture;
        placeholder.replaceWith(img);
      } catch {
        // ignorer fejl
      }
    };
  }

  init();
</script>