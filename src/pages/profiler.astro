---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Profiler verificeret med @nostr.dk | nostr.dk"
  description="Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse."
>
  <div class="page-header">
    <h1>Profiler verificeret med @nostr.dk</h1>
    <p>Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse.</p>
  </div>

  <div class="profiler-wrap">
    <div id="loading" class="loading-msg">Henter profiler…</div>
    <div id="grid" class="profiler-grid"></div>
  </div>

  <!-- NIP-05 registrering -->
  <section class="nostr-nip05" id="nostr-nip05">
    <h2>Få din egen <span style="font-size: 0.75em;">(NIP-05 adresse)</span></h2>
    <p>
      Tjek om dit ønskede navn er ledigt, følg anvisningerne og betal 2.100 sats
      via Lightning — din adresse er aktiv inden for få minutter.
    </p>

    <div class="nip05-register">
      <div id="nip05-step1">
        <div class="nip05-field">
          <div class="nip05-name-row" id="nip05NameRow">
            <input type="text" id="nip05Name" placeholder="ditnavnher"
              autocomplete="off" autocapitalize="none" spellcheck="false" />
            <span class="nip05-suffix">@nostr.dk</span>
          </div>
          <div class="nip05-status" id="nip05Status"></div>
        </div>
        <p class="nip05-price">
          @nostr.dk nip-05 adresse for kun <strong>2.100 sats</strong> via
          <a href="https://enogtyve.org/da/laer-mere/lightning/" target="_blank" rel="noopener noreferrer">Lightning</a> ⚡
        </p>
        <button id="nip05ProceedBtn" class="cta" disabled data-umami-event="nip05-profiler-button">Næste</button>
      </div>

      <div id="nip05-step2" style="display: none;">
        <div class="nip05-confirmed" id="nip05Confirmed"></div>
        <div class="nip05-instructions">
          <p>Udfyld felterne i betalingsformularen som åbner i et nyt vindue:</p>
          <ol>
            <li>Skriv <strong id="nip05NameReminder"></strong> i feltet <em>"Din nostr adresse @nostr.dk"</em> — kun navnet, ikke @nostr.dk</li>
            <li>Indsæt din Nostr public key (npub1… eller hex)</li>
            <li>Betal 2.100 sats via Lightning</li>
          </ol>
        </div>
        <button id="nip05PayBtn" class="cta" data-umami-event="nip05-profiler-pay">Gå til betaling ⚡</button>
        <button id="nip05BackBtn" class="nip05-back-btn">← Vælg et andet navn</button>
      </div>
    </div>
  </section>

</NostrLayout>

<style is:global>
  .profiler-wrap {
    padding: 0 0 80px;
  }

  .loading-msg {
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    padding: 60px 0;
  }

  .profiler-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    margin-top: 10px;
    align-items: flex-start;
    justify-content: center;
}

  .profil-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex: 0 0 110px;
  }

  .profil-col.staggered {
    margin-top: 50px;
  }

  .profil-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    padding: 8px;
    border-radius: 12px;
    width: 110px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .profil-card:hover {
    transform: translateY(-4px);
    background: rgba(108, 79, 150, 0.15);
  }

  .profil-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 79, 150, 0.6);
    display: block;
    margin-bottom: 10px;
  }

  .profil-avatar-placeholder {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    border: 2px solid rgba(108, 79, 150, 0.3);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.2), rgba(55, 26, 118, 0.2));
    display: block;
    margin-bottom: 10px;
    flex-shrink: 0;
  }

  .profil-nip05 {
    font-size: 0.7rem;
    line-height: 1.3;
    word-break: break-all;
  }

  .profil-name {
    color: rgba(200, 180, 230, 0.85);
    font-weight: 500;
  }

  .profil-domain {
    color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .profil-col {
      flex: 0 0 80px;
    }

    .profil-card {
      width: 80px;
    }

    .profil-avatar,
    .profil-avatar-placeholder {
      width: 64px;
      height: 64px;
    }

    .profil-col.staggered {
      margin-top: 36px;
    }
  }
</style>

<script>
  const NOSTR_JSON_URL = "https://nostr.dk/.well-known/nostr.json";

  const grid = document.getElementById("grid")!;
  const loading = document.getElementById("loading")!;

  function makeCard(name: string, pubkey: string): HTMLAnchorElement {
    const card = document.createElement("a");
    card.className = "profil-card";
    card.href = `https://primal.net/p/${pubkey}`;
    card.target = "_blank";
    card.rel = "noopener noreferrer";

    const placeholder = document.createElement("div");
    placeholder.className = "profil-avatar-placeholder";

    const nip05 = document.createElement("div");
    nip05.className = "profil-nip05";
    nip05.innerHTML = `<span class="profil-name">${name}</span><span class="profil-domain">@nostr.dk</span>`;

    card.appendChild(placeholder);
    card.appendChild(nip05);
    return card;
  }

  async function init() {
    let names: Record<string, string> = {};
    try {
      const res = await fetch(NOSTR_JSON_URL);
      const data = await res.json();
      names = data.names || {};
    } catch {
      loading.textContent = "Kunne ikke hente brugerliste — prøv igen.";
      return;
    }

    const entries = Object.entries(names).sort(() => Math.random() - 0.5);
    if (entries.length === 0) {
      loading.textContent = "Ingen profiler endnu.";
      return;
    }

    loading.style.display = "none";

    const CARDS_PER_COL = 2;
    const cards: Record<string, HTMLElement> = {};

    let colIndex = 0;
    let col: HTMLDivElement | null = null;
    let cardsInCol = 0;

    for (const [name, pubkey] of entries) {
      if (!col || cardsInCol >= CARDS_PER_COL) {
        col = document.createElement("div");
        col.className = "profil-col" + (colIndex % 2 === 1 ? " staggered" : "");
        grid.appendChild(col);
        colIndex++;
        cardsInCol = 0;
      }

      const card = makeCard(name, pubkey);
      col.appendChild(card);
      cards[pubkey] = card;
      cardsInCol++;
    }

    const pubkeys = entries.map(([, pubkey]) => pubkey);
    try {
      const res = await fetch(
        `/.netlify/functions/nostr-profiles?pubkeys=${pubkeys.join(",")}`
      );
      const profiles = await res.json();

      for (const [pubkey, profile] of Object.entries(profiles) as [string, any][]) {
        if (!profile?.picture) continue;
        const card = cards[pubkey];
        if (!card) continue;

        const placeholder = card.querySelector(".profil-avatar-placeholder");
        if (!placeholder) continue;

        const img = document.createElement("img");
        img.className = "profil-avatar";
        img.alt = profile.display_name || "";
        img.loading = "lazy";
        img.onerror = () => {};
        img.src = profile.picture;
        placeholder.replaceWith(img);
      }
    } catch {}
  }

  init();
</script>

<script is:inline>
  (function () {
    const BTCPAY_FORM_URL = "https://btcpay.ideasarelikeflames.org/forms/322ff6ea-8e6b-448f-85f8-ddb5bc5687b6";
    let nameAvailable = false;
    let checkTimeout;

    function setStatus(type, icon, text) {
      document.getElementById("nip05Status").className = "nip05-status " + type;
      document.getElementById("nip05Status").textContent = icon + " " + text;
      document.getElementById("nip05NameRow").className = "nip05-name-row " + (type === "available" ? "valid" : type === "taken" ? "taken" : "");
    }

    function clearStatus() {
      document.getElementById("nip05Status").className = "nip05-status";
      document.getElementById("nip05Status").textContent = "";
      document.getElementById("nip05NameRow").className = "nip05-name-row";
      nameAvailable = false;
      document.getElementById("nip05ProceedBtn").disabled = true;
    }

    async function checkAvailability(name) {
      if (!name) { clearStatus(); return; }
      if (!/^[a-z0-9_-]+$/.test(name)) {
        setStatus("taken", "✗", "Kun små bogstaver, tal, _ og - er tilladt");
        nameAvailable = false;
        document.getElementById("nip05ProceedBtn").disabled = true;
        return;
      }
      setStatus("checking", "…", "Tjekker tilgængelighed…");
      try {
        const res = await fetch("/.netlify/functions/check-name?name=" + encodeURIComponent(name));
        const data = await res.json();
        if (data.available) {
          setStatus("available", "✓", "Ledigt!");
          nameAvailable = true;
          document.getElementById("nip05ProceedBtn").disabled = false;
        } else {
          setStatus("taken", "✗", "Navnet er allerede taget — prøv et andet");
          nameAvailable = false;
          document.getElementById("nip05ProceedBtn").disabled = true;
        }
      } catch {
        setStatus("error", "!", "Kunne ikke tjekke — prøv igen");
        nameAvailable = false;
        document.getElementById("nip05ProceedBtn").disabled = true;
      }
    }

    document.getElementById("nip05Name").addEventListener("input", function () {
      const val = this.value.toLowerCase().replace(/[^a-z0-9_-]/g, "");
      if (this.value !== val) this.value = val;
      clearTimeout(checkTimeout);
      if (!val) { clearStatus(); return; }
      checkTimeout = setTimeout(() => checkAvailability(val), 500);
    });

    document.getElementById("nip05ProceedBtn").addEventListener("click", function () {
      if (!nameAvailable) return;
      const name = document.getElementById("nip05Name").value.trim();
      document.getElementById("nip05Confirmed").textContent = "✓ " + name + "@nostr.dk er ledigt";
      document.getElementById("nip05NameReminder").textContent = name;
      document.getElementById("nip05-step1").style.display = "none";
      document.getElementById("nip05-step2").style.display = "block";
    });

    document.getElementById("nip05PayBtn").addEventListener("click", function () {
      const w = 620, h = 820;
      window.open(BTCPAY_FORM_URL, "nip05Window", `width=${w},height=${h},top=${screen.height/2-h/2},left=${screen.width/2-w/2},resizable=yes,scrollbars=yes`);
    });

    document.getElementById("nip05BackBtn").addEventListener("click", function () {
      document.getElementById("nip05-step2").style.display = "none";
      document.getElementById("nip05-step1").style.display = "block";
    });
  })();
</script>