---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Profiler verificeret med @nostr.dk | nostr.dk"
  description="Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse."
>
  <div class="page-header">
    <h1>Profiler verificeret med @nostr.dk</h1>
    <p>Disse brugere har valgt at verificere deres Nostr-profil med en @nostr.dk adresse.</p>
  </div>

  <div class="profiler-wrap">
    <div id="loading" class="loading-msg">Henter profiler…</div>
    <div id="grid" class="profiler-grid"></div>
  </div>

  <!-- NIP-05 registrering -->
  <div class="register-wrap">
    <div id="step1" class="register-form">
      <div class="field">
        <label for="name">Vælg din nostr adresse</label>
        <div class="nip05-name-row" id="nameRow">
          <input
            type="text"
            id="name"
            placeholder="ditnavnher"
            autocomplete="off"
            autocapitalize="none"
            spellcheck="false"
          />
          <span class="nip05-suffix">@nostr.dk</span>
        </div>
        <div class="status" id="nameStatus"></div>
      </div>

      <p class="price-note">
        @nostr.dk NIP-05 adresse for kun <strong>2.100 sats</strong> via
        <a href="https://enogtyve.org/da/laer-mere/lightning/" target="_blank" rel="noopener noreferrer">Lightning</a> ⚡
      </p>

      <button
        id="proceedBtn"
        class="cta"
        disabled
        data-umami-event="nip05-profiler-næste"
        style="margin-top: 20px; width: 100%;">Næste</button>
    </div>

    <div id="step2" class="register-form" style="display: none;">
      <div class="confirmed-name" id="confirmedName"></div>
      <div class="instructions">
        <p>Udfyld felterne i betalingsformularen som åbner i et nyt vindue:</p>
        <ol>
          <li>
            Skriv <strong id="nameReminder"></strong> i feltet
            <em>"Din nostr adresse @nostr.dk"</em> — kun navnet, ikke @nostr.dk
          </li>
          <li>Indsæt din Nostr public key (npub1… eller hex)</li>
          <li>Betal 2.100 sats via Lightning</li>
        </ol>
      </div>
      <button
        id="payBtn"
        class="cta"
        data-umami-event="nip05-profiler-betal"
        style="margin-top: 20px; width: 100%;">Gå til betaling ⚡</button>
      <button id="backBtn" class="back-btn">← Vælg et andet navn</button>
    </div>
  </div>

</NostrLayout>

<style is:global>
  .profiler-wrap {
    padding: 0 0 80px;
  }

  .loading-msg {
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    padding: 60px 0;
  }

  .profiler-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    margin-top: 10px;
    align-items: flex-start;
    justify-content: center;
  }

  .profil-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex: 0 0 110px;
  }

  .profil-col.staggered {
    margin-top: 50px;
  }

  .profil-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    padding: 8px;
    border-radius: 12px;
    width: 110px;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .profil-card:hover {
    transform: translateY(-4px);
    background: rgba(108, 79, 150, 0.15);
  }

  .profil-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 79, 150, 0.6);
    display: block;
    margin-bottom: 10px;
  }

  .profil-avatar-placeholder {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    border: 2px solid rgba(108, 79, 150, 0.3);
    background: linear-gradient(135deg, rgba(108, 79, 150, 0.2), rgba(55, 26, 118, 0.2));
    display: block;
    margin-bottom: 10px;
    flex-shrink: 0;
  }

  .profil-nip05 {
    font-size: 0.7rem;
    line-height: 1.3;
    word-break: break-all;
  }

  .profil-name {
    color: rgba(200, 180, 230, 0.85);
    font-weight: 500;
  }

  .profil-domain {
    color: rgba(255, 255, 255, 0.2);
  }

  /* ---- Formular (identisk med getnip05.astro) ---- */
  .register-wrap {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 80px;
  }

  .register-form {
    text-align: left;
  }

  .field {
    margin-bottom: 1.4rem;
  }

  .register-wrap label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #e0e0e0;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nip05-name-row {
    display: flex;
    align-items: stretch;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .nip05-name-row:focus-within {
    border-color: rgba(108, 79, 150, 0.8);
  }

  .nip05-name-row.valid {
    border-color: #4caf50;
  }

  .nip05-name-row.taken {
    border-color: #e05050;
  }

  .nip05-name-row input[type="text"] {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 0.7rem 0.9rem;
  }

  .nip05-suffix {
    padding: 0 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
    white-space: nowrap;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
  }

  .status {
    font-size: 0.82rem;
    margin-top: 0.4rem;
    min-height: 1.1em;
  }

  .status.checking { color: rgba(255, 255, 255, 0.4); }
  .status.available { color: #4caf50; }
  .status.taken { color: #e05050; }
  .status.error { color: #e08050; }

  .price-note {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0.5rem 0 0;
  }

  .price-note strong { color: #fff; }
  .price-note a { color: rgba(255, 255, 255, 0.6); }

  .cta:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  .confirmed-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #4caf50;
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .instructions {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem 1.2rem;
    margin-bottom: 0.5rem;
  }

  .instructions p {
    font-size: 0.9rem;
    color: #e0e0e0;
    margin-bottom: 0.8rem;
  }

  .instructions ol {
    padding-left: 1.2rem;
    color: #d0d0d0;
    font-size: 0.88rem;
    line-height: 1.8;
  }

  .instructions strong { color: #fff; }
  .instructions em { color: rgba(255, 255, 255, 0.6); font-style: normal; }

  .back-btn {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.82rem;
    cursor: pointer;
    margin-top: 1rem;
    padding: 0;
    display: block;
    transition: color 0.2s;
  }

  .back-btn:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .profil-col {
      flex: 0 0 80px;
    }

    .profil-card {
      width: 80px;
    }

    .profil-avatar,
    .profil-avatar-placeholder {
      width: 64px;
      height: 64px;
    }

    .profil-col.staggered {
      margin-top: 36px;
    }

    .register-wrap {
      padding: 0 0 40px;
    }
  }
</style>

<script>
  const NOSTR_JSON_URL = "https://nostr.dk/.well-known/nostr.json";

  const grid = document.getElementById("grid")!;
  const loading = document.getElementById("loading")!;

  function makeCard(name: string, pubkey: string): HTMLAnchorElement {
    const card = document.createElement("a");
    card.className = "profil-card";
    card.href = `https://primal.net/p/${pubkey}`;
    card.target = "_blank";
    card.rel = "noopener noreferrer";

    const placeholder = document.createElement("div");
    placeholder.className = "profil-avatar-placeholder";

    const nip05 = document.createElement("div");
    nip05.className = "profil-nip05";
    nip05.innerHTML = `<span class="profil-name">${name}</span><span class="profil-domain">@nostr.dk</span>`;

    card.appendChild(placeholder);
    card.appendChild(nip05);
    return card;
  }

  async function init() {
    let names: Record<string, string> = {};
    try {
      const res = await fetch(NOSTR_JSON_URL);
      const data = await res.json();
      names = data.names || {};
    } catch {
      loading.textContent = "Kunne ikke hente brugerliste — prøv igen.";
      return;
    }

    const entries = Object.entries(names).sort(() => Math.random() - 0.5);
    if (entries.length === 0) {
      loading.textContent = "Ingen profiler endnu.";
      return;
    }

    loading.style.display = "none";

    const CARDS_PER_COL = 2;
    const cards: Record<string, HTMLElement> = {};

    let colIndex = 0;
    let col: HTMLDivElement | null = null;
    let cardsInCol = 0;

    for (const [name, pubkey] of entries) {
      if (!col || cardsInCol >= CARDS_PER_COL) {
        col = document.createElement("div");
        col.className = "profil-col" + (colIndex % 2 === 1 ? " staggered" : "");
        grid.appendChild(col);
        colIndex++;
        cardsInCol = 0;
      }

      const card = makeCard(name, pubkey);
      col.appendChild(card);
      cards[pubkey] = card;
      cardsInCol++;
    }

    const pubkeys = entries.map(([, pubkey]) => pubkey);
    try {
      const res = await fetch(
        `/.netlify/functions/nostr-profiles?pubkeys=${pubkeys.join(",")}`
      );
      const profiles = await res.json();

      for (const [pubkey, profile] of Object.entries(profiles) as [string, any][]) {
        if (!profile?.picture) continue;
        const card = cards[pubkey];
        if (!card) continue;

        const placeholder = card.querySelector(".profil-avatar-placeholder");
        if (!placeholder) continue;

        const img = document.createElement("img");
        img.className = "profil-avatar";
        img.alt = profile.display_name || "";
        img.loading = "lazy";
        img.onerror = () => {};
        img.src = profile.picture;
        placeholder.replaceWith(img);
      }
    } catch {}
  }

  init();
</script>

<script is:inline>
  (function () {
    const BTCPAY_FORM_URL = "https://btcpay.ideasarelikeflames.org/forms/322ff6ea-8e6b-448f-85f8-ddb5bc5687b6";
    let nameAvailable = false;
    let checkTimeout;

    function setStatus(type, icon, text) {
      document.getElementById("nameStatus").className = "status " + type;
      document.getElementById("nameStatus").textContent = icon + " " + text;
      document.getElementById("nameRow").className = "nip05-name-row " + (type === "available" ? "valid" : type === "taken" ? "taken" : "");
    }

    function clearStatus() {
      document.getElementById("nameStatus").className = "status";
      document.getElementById("nameStatus").textContent = "";
      document.getElementById("nameRow").className = "nip05-name-row";
      nameAvailable = false;
      document.getElementById("proceedBtn").disabled = true;
    }

    async function checkAvailability(name) {
      if (!name) { clearStatus(); return; }
      if (!/^[a-z0-9_-]+$/.test(name)) {
        setStatus("taken", "✗", "Kun små bogstaver, tal, _ og - er tilladt");
        nameAvailable = false;
        document.getElementById("proceedBtn").disabled = true;
        return;
      }
      setStatus("checking", "…", "Tjekker tilgængelighed…");
      try {
        const res = await fetch("/.netlify/functions/check-name?name=" + encodeURIComponent(name));
        const data = await res.json();
        if (data.available) {
          setStatus("available", "✓", "Ledigt!");
          nameAvailable = true;
          document.getElementById("proceedBtn").disabled = false;
        } else {
          setStatus("taken", "✗", "Navnet er allerede taget — prøv et andet");
          nameAvailable = false;
          document.getElementById("proceedBtn").disabled = true;
        }
      } catch {
        setStatus("error", "!", "Kunne ikke tjekke — prøv igen");
        nameAvailable = false;
        document.getElementById("proceedBtn").disabled = true;
      }
    }

    document.getElementById("name").addEventListener("input", function () {
      const val = this.value.toLowerCase().replace(/[^a-z0-9_-]/g, "");
      if (this.value !== val) this.value = val;
      clearTimeout(checkTimeout);
      if (!val) { clearStatus(); return; }
      checkTimeout = setTimeout(() => checkAvailability(val), 500);
    });

    document.getElementById("proceedBtn").addEventListener("click", function () {
      if (!nameAvailable) return;
      const name = document.getElementById("name").value.trim();
      document.getElementById("confirmedName").textContent = "✓ " + name + "@nostr.dk er ledigt";
      document.getElementById("nameReminder").textContent = name;
      document.getElementById("step1").style.display = "none";
      document.getElementById("step2").style.display = "block";
    });

    document.getElementById("payBtn").addEventListener("click", function () {
      window.open(BTCPAY_FORM_URL, "btcpay", "width=600,height=700,resizable=yes");
    });

    document.getElementById("backBtn").addEventListener("click", function () {
      document.getElementById("step2").style.display = "none";
      document.getElementById("step1").style.display = "block";
    });
  })();
</script>