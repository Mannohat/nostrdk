---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Test betaling | nostr.dk"
  description="Test af nyt betalingsflow for NIP-05 registrering."
>
  <div class="page-header">
    <h1>Test betaling</h1>
    <p>Test af nyt betalingsflow — påvirker ikke eksisterende sider.</p>
  </div>

  <div class="register-wrap">
    <!-- Trin 1: Tjek navn -->
    <div id="step1" class="register-form">
      <div class="field">
        <label for="name">Vælg din nostr adresse</label>
        <div class="nip05-name-row" id="nameRow">
          <input
            type="text"
            id="name"
            placeholder="ditnavnher"
            autocomplete="off"
            autocapitalize="none"
            spellcheck="false"
          />
          <span class="nip05-suffix">@nostr.dk</span>
        </div>
        <div class="status" id="nameStatus"></div>
      </div>

      <p class="price-note">
        @nostr.dk NIP-05 adresse for kun <strong>2.100 sats</strong> via
        <a
          href="https://enogtyve.org/da/laer-mere/lightning/"
          target="_blank"
          rel="noopener noreferrer">Lightning</a
        > ⚡
      </p>

      <button
        id="proceedBtn"
        class="cta"
        disabled
        style="margin-top: 20px; width: 100%;">Næste</button
      >
    </div>

    <!-- Trin 2: Indtast npub og betal -->
    <div id="step2" class="register-form" style="display: none;">
      <div class="confirmed-name" id="confirmedName"></div>

      <div class="field">
        <label for="pubkey">Din Nostr public key</label>
        <input
          type="text"
          id="pubkey"
          placeholder="npub1… eller hex"
          autocomplete="off"
          autocapitalize="none"
          spellcheck="false"
          class="pubkey-input"
        />
        <div class="status" id="pubkeyStatus"></div>
      </div>

      <div class="instructions">
        <p>Hvad sker der næste:</p>
        <ol>
          <li>Klik "Gå til betaling ⚡"</li>
          <li>Betal 2.100 sats via Lightning</li>
          <li>Din NIP-05 adresse aktiveres automatisk</li>
        </ol>
      </div>

      <button
        id="payBtn"
        class="cta"
        style="margin-top: 20px; width: 100%;">Gå til betaling ⚡</button
      >
      <div class="status" id="payStatus"></div>
      <button id="backBtn" class="back-btn">← Vælg et andet navn</button>
    </div>
  </div>
</NostrLayout>

<style>
  .register-wrap {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 80px;
  }

  .register-form {
    text-align: left;
  }

  .field {
    margin-bottom: 1.4rem;
  }

  label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #e0e0e0;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nip05-name-row {
    display: flex;
    align-items: stretch;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .nip05-name-row:focus-within {
    border-color: rgba(108, 79, 150, 0.8);
  }

  .nip05-name-row.valid {
    border-color: #4caf50;
  }

  .nip05-name-row.taken {
    border-color: #e05050;
  }

  .nip05-name-row input[type="text"] {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 0.7rem 0.9rem;
  }

  .nip05-suffix {
    padding: 0 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
    white-space: nowrap;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
  }

  .pubkey-input {
    width: 100%;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    color: #fff;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .pubkey-input:focus {
    border-color: rgba(108, 79, 150, 0.8);
  }

  .status {
    font-size: 0.82rem;
    margin-top: 0.4rem;
    min-height: 1.1em;
  }

  .status.checking { color: rgba(255, 255, 255, 0.4); }
  .status.available { color: #4caf50; }
  .status.taken { color: #e05050; }
  .status.error { color: #e08050; }

  .price-note {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0.5rem 0 0;
  }

  .price-note strong { color: #fff; }
  .price-note a { color: rgba(255, 255, 255, 0.6); }

  .cta:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  .confirmed-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #4caf50;
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .instructions {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem 1.2rem;
    margin-bottom: 0.5rem;
  }

  .instructions p {
    font-size: 0.9rem;
    color: #e0e0e0;
    margin-bottom: 0.8rem;
  }

  .instructions ol {
    padding-left: 1.2rem;
    color: #d0d0d0;
    font-size: 0.88rem;
    line-height: 1.8;
  }

  .back-btn {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.82rem;
    cursor: pointer;
    margin-top: 1rem;
    padding: 0;
    display: block;
    transition: color 0.2s;
  }

  .back-btn:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .register-wrap {
      padding: 0 0 40px;
    }
  }
</style>

<script is:inline>
  (function () {
    let nameAvailable = false;
    let confirmedNameValue = "";
    let checkTimeout;

    function setStatus(id, type, icon, text) {
      const el = document.getElementById(id);
      el.className = "status " + type;
      el.textContent = icon + " " + text;
    }

    function clearStatus() {
      document.getElementById("nameStatus").className = "status";
      document.getElementById("nameStatus").textContent = "";
      document.getElementById("nameRow").className = "nip05-name-row";
      nameAvailable = false;
      document.getElementById("proceedBtn").disabled = true;
    }

    async function checkAvailability(name) {
      if (!name) { clearStatus(); return; }
      if (!/^[a-z0-9_-]+$/.test(name)) {
        setStatus("nameStatus", "taken", "✗", "Kun små bogstaver, tal, _ og - er tilladt");
        document.getElementById("nameRow").className = "nip05-name-row taken";
        nameAvailable = false;
        document.getElementById("proceedBtn").disabled = true;
        return;
      }
      setStatus("nameStatus", "checking", "…", "Tjekker tilgængelighed…");
      try {
        const res = await fetch("/.netlify/functions/check-name?name=" + encodeURIComponent(name));
        const data = await res.json();
        if (data.available) {
          setStatus("nameStatus", "available", "✓", "Ledigt!");
          document.getElementById("nameRow").className = "nip05-name-row valid";
          nameAvailable = true;
          document.getElementById("proceedBtn").disabled = false;
        } else {
          setStatus("nameStatus", "taken", "✗", "Navnet er allerede taget — prøv et andet");
          document.getElementById("nameRow").className = "nip05-name-row taken";
          nameAvailable = false;
          document.getElementById("proceedBtn").disabled = true;
        }
      } catch {
        setStatus("nameStatus", "error", "!", "Kunne ikke tjekke — prøv igen");
        nameAvailable = false;
        document.getElementById("proceedBtn").disabled = true;
      }
    }

    document.getElementById("name").addEventListener("input", function () {
      const val = this.value.toLowerCase().replace(/[^a-z0-9_-]/g, "");
      if (this.value !== val) this.value = val;
      clearTimeout(checkTimeout);
      if (!val) { clearStatus(); return; }
      checkTimeout = setTimeout(() => checkAvailability(val), 500);
    });

    document.getElementById("proceedBtn").addEventListener("click", function () {
      if (!nameAvailable) return;
      confirmedNameValue = document.getElementById("name").value.trim();
      document.getElementById("confirmedName").textContent = "✓ " + confirmedNameValue + "@nostr.dk er ledigt";
      document.getElementById("step1").style.display = "none";
      document.getElementById("step2").style.display = "block";
    });

    document.getElementById("payBtn").addEventListener("click", async function () {
      const pubkey = document.getElementById("pubkey").value.trim();
      if (!pubkey) {
        setStatus("pubkeyStatus", "error", "!", "Indtast din Nostr public key");
        return;
      }

      const btn = document.getElementById("payBtn");
      btn.disabled = true;
      btn.textContent = "Opretter betaling…";
      setStatus("payStatus", "checking", "…", "Forbinder til BTCPay…");

      try {
        const res = await fetch("/.netlify/functions/create-nip05-invoice", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name: confirmedNameValue, pubkey: pubkey }),
        });

        const data = await res.json();

        if (data.checkoutLink) {
          window.location.href = data.checkoutLink;
        } else {
          throw new Error("Intet checkout link");
        }
      } catch (err) {
        setStatus("payStatus", "error", "!", "Noget gik galt — prøv igen");
        btn.disabled = false;
        btn.textContent = "Gå til betaling ⚡";
      }
    });

    document.getElementById("backBtn").addEventListener("click", function () {
      document.getElementById("step2").style.display = "none";
      document.getElementById("step1").style.display = "block";
    });
  })();
</script>