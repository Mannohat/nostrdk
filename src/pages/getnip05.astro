---
import NostrLayout from "../layouts/NostrLayout.astro";
import Nip05RegisterForm from "../components/Nip05RegisterForm.astro";
import Nip05Teaser from "../components/Nip05Teaser.astro";
---

<NostrLayout
  title="Få din NIP-05 identitet | Nostr.dk"
  description="Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-identitet."
>
  <div class="page-header">
    <h1>Få din Nostr-identitet</h1>
    <p>
      Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-profil.
    </p>
  </div>

  <Nip05Teaser gridId="teaserGrid" deterministic />

  <Nip05RegisterForm variant="page" umamiNext="nip05-næste" umamiPay="nip05-betal" />
</NostrLayout>
