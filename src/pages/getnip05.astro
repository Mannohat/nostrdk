---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Få din NIP-05 identitet | nostr.dk"
  description="Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-identitet."
>
  <div class="page-header">
    <h1>Få din Nostr-identitet</h1>
    <p>
      Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-profil.
    </p>
  </div>

  <!-- Profil teaser udenfor register-wrap -->
  <div class="nip05-teaser">
    <p class="nip05-teaser-label">Allerede verificeret med @nostr.dk</p>
    <div class="nip05-teaser-grid" id="teaserGrid"></div>
    <p class="teaser-see-more"><a href="/profiler">Se flere profiler →</a></p>
  </div>

  <div class="register-wrap">
    <!-- Trin 1: Tjek navn -->
    <div id="step1" class="register-form">
      <div class="field">
        <label for="name">Vælg din nostr adresse</label>
        <div class="nip05-name-row" id="nameRow">
          <input
            type="text"
            id="name"
            placeholder="ditnavnher"
            autocomplete="off"
            autocapitalize="none"
            spellcheck="false"
          />
          <span class="nip05-suffix">@nostr.dk</span>
        </div>
        <div class="status" id="nameStatus"></div>
      </div>

      <p class="price-note">
        @nostr.dk NIP-05 adresse for kun <strong>2.100 sats</strong> via
        <a
          href="https://enogtyve.org/da/laer-mere/lightning/"
          target="_blank"
          rel="noopener noreferrer">Lightning</a
        > ⚡
      </p>

      <button
        id="proceedBtn"
        class="cta"
        disabled
        data-umami-event="nip05-næste"
        style="margin-top: 20px; width: 100%;">Næste</button
      >
    </div>

    <!-- Trin 2: Indtast npub og betal -->
    <div id="step2" class="register-form" style="display: none;">
      <div class="confirmed-name" id="confirmedName"></div>

      <div class="field">
        <label for="pubkey">Din Nostr public key</label>
        <input
          type="text"
          id="pubkey"
          placeholder="npub1… eller hex"
          autocomplete="off"
          autocapitalize="none"
          spellcheck="false"
          class="pubkey-input"
        />
        <div class="status" id="pubkeyStatus"></div>
      </div>

      <div class="instructions">
        <p>Hvad sker der næste:</p>
        <ol>
          <li>Klik "Gå til betaling ⚡"</li>
          <li>Betal 2.100 sats via Lightning</li>
          <li>Din NIP-05 adresse aktiveres automatisk</li>
        </ol>
      </div>

      <button
        id="payBtn"
        class="cta"
        disabled
        data-umami-event="nip05-betal"
        style="margin-top: 20px; width: 100%;">Gå til betaling ⚡</button
      >
      <div class="status" id="payStatus"></div>
      <button id="backBtn" class="back-btn">← Vælg et andet navn</button>
    </div>
  </div>
</NostrLayout>

<style>
  .register-wrap {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 80px;
  }

  /* ---- Profil teaser ---- */
  .nip05-teaser {
    margin: 0 0 30px;
  }

  .nip05-teaser-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .nip05-teaser-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 10px;
    align-items: flex-start;
  }

  .teaser-see-more {
    text-align: center;
    margin-top: 16px;
    margin-bottom: 0;
    font-size: 0.78rem;
  }

  .teaser-see-more a {
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    letter-spacing: 0.03em;
    font-weight: normal;
    transition: color 0.2s;
  }

  .teaser-see-more a:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  /* ---- Formular ---- */
  .register-form {
    text-align: left;
  }

  .field {
    margin-bottom: 1.4rem;
  }

  label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #e0e0e0;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nip05-name-row {
    display: flex;
    align-items: stretch;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .nip05-name-row:focus-within {
    border-color: rgba(108, 79, 150, 0.8);
  }

  .nip05-name-row.valid { border-color: #4caf50; }
  .nip05-name-row.taken { border-color: #e05050; }

  .nip05-name-row input[type="text"] {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 0.7rem 0.9rem;
  }

  .nip05-suffix {
    padding: 0 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
    white-space: nowrap;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
  }

  .pubkey-input {
    width: 100%;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    color: #fff;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .pubkey-input:focus {
    border-color: rgba(108, 79, 150, 0.8);
  }

  .status {
    font-size: 0.82rem;
    margin-top: 0.4rem;
    min-height: 1.1em;
  }

  .status.checking { color: rgba(255, 255, 255, 0.4); }
  .status.available { color: #4caf50; }
  .status.taken { color: #e05050; }
  .status.error { color: #e08050; }

  .price-note {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0.5rem 0 0;
  }

  .price-note strong { color: #fff; }
  .price-note a { color: rgba(255, 255, 255, 0.6); }

  .cta:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  .confirmed-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #4caf50;
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .instructions {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem 1.2rem;
    margin-bottom: 0.5rem;
  }

  .instructions p {
    font-size: 0.9rem;
    color: #e0e0e0;
    margin-bottom: 0.8rem;
  }

  .instructions ol {
    padding-left: 1.2rem;
    color: #d0d0d0;
    font-size: 0.88rem;
    line-height: 1.8;
  }

  .instructions strong { color: #fff; }
  .instructions em { color: rgba(255, 255, 255, 0.6); font-style: normal; }

  .back-btn {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.82rem;
    cursor: pointer;
    margin-top: 1rem;
    padding: 0;
    display: block;
    transition: color 0.2s;
  }

  .back-btn:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .register-wrap {
      padding: 0 0 40px;
    }
  }
</style>

<script>
  const nameInput = document.getElementById("name") as HTMLInputElement;
  const nameRow = document.getElementById("nameRow")!;
  const nameStatus = document.getElementById("nameStatus")!;
  const proceedBtn = document.getElementById("proceedBtn") as HTMLButtonElement;
  const step1 = document.getElementById("step1")!;
  const step2 = document.getElementById("step2")!;
  const confirmedNameEl = document.getElementById("confirmedName")!;
  const backBtn = document.getElementById("backBtn")!;
  const pubkeyInput = document.getElementById("pubkey") as HTMLInputElement;
  const pubkeyStatus = document.getElementById("pubkeyStatus")!;
  const payBtn = document.getElementById("payBtn") as HTMLButtonElement;
  const payStatus = document.getElementById("payStatus")!;

  let nameAvailable = false;
  let checkTimeout: ReturnType<typeof setTimeout>;
  let confirmedName = "";

  function validatePubkey(val: string) {
    return /^npub1[a-z0-9]{58}$/.test(val) || /^[0-9a-f]{64}$/.test(val);
  }

  // Profil teaser
  (async function loadTeaser() {
    try {
      const res = await fetch("/.well-known/nostr.json");
      const data = await res.json();
      const names = data.names || {};
      const entries = Object.entries(names).sort(() => Math.random() - 0.5).slice(0, 20);
      const pubkeys = entries.map(([, pubkey]) => pubkey);
      const teaserGrid = document.getElementById("teaserGrid");
      if (!teaserGrid) return;

      const profileRes = await fetch(`/.netlify/functions/nostr-profiles?pubkeys=${pubkeys.join(",")}`);
      const profiles = await profileRes.json();
      const withPicture = entries.filter(([, pubkey]) => profiles[pubkey]?.picture).slice(0, 11);

      const isMobile = window.innerWidth < 768;
      const imgSize = isMobile ? "48px" : "64px";
      const colWidth = isMobile ? "56px" : "72px";
      const staggerOffset = isMobile ? "0px" : "36px"; // Ingen stagger på mobil

      let colIndex = 0;
      let col: HTMLDivElement | null = null;
      let cardsInCol = 0;
      const maxPerCol = isMobile ? 3 : 2; // Flere per kolonne på mobil = færre kolonner = pænere

      for (const [, pubkey] of withPicture) {
        const profile = profiles[pubkey];
        if (!col || cardsInCol >= maxPerCol) {
          col = document.createElement("div");
          col.style.display = "flex";
          col.style.flexDirection = "column";
          col.style.alignItems = "center";
          col.style.gap = "10px";
          col.style.flex = `0 0 ${colWidth}`;
          // Kun stagger på desktop
          if (!isMobile && colIndex % 2 === 1) col.style.marginTop = staggerOffset;
          teaserGrid.appendChild(col);
          colIndex++;
          cardsInCol = 0;
        }
        const img = document.createElement("img");
        img.style.width = imgSize;
        img.style.height = imgSize;
        img.style.borderRadius = "50%";
        img.style.objectFit = "cover";
        img.style.border = "2px solid rgba(108, 79, 150, 0.6)";
        img.style.display = "block";
        img.src = profile.picture;
        img.alt = "";
        img.loading = "lazy";
        img.onerror = () => {};
        col.appendChild(img);
        cardsInCol++;
      }
    } catch {}
  })();

  function setStatus(type: string, icon: string, text: string) {
    nameStatus.className = `status ${type}`;
    nameStatus.textContent = `${icon} ${text}`;
    nameRow.className = "nip05-name-row " + (type === "available" ? "valid" : type === "taken" ? "taken" : "");
  }

  function clearStatus() {
    nameStatus.className = "status";
    nameStatus.textContent = "";
    nameRow.className = "nip05-name-row";
    nameAvailable = false;
    proceedBtn.disabled = true;
  }

  async function checkAvailability(name: string) {
    if (!name) { clearStatus(); return; }
    if (!/^[a-z0-9_-]+$/.test(name)) {
      setStatus("taken", "✗", "Kun små bogstaver, tal, _ og - er tilladt");
      nameAvailable = false;
      proceedBtn.disabled = true;
      return;
    }
    setStatus("checking", "…", "Tjekker tilgængelighed…");
    try {
      const res = await fetch(`/.netlify/functions/check-name?name=${encodeURIComponent(name)}`);
      const data = await res.json();
      if (data.available) {
        setStatus("available", "✓", "Ledigt!");
        nameAvailable = true;
        proceedBtn.disabled = false;
      } else {
        setStatus("taken", "✗", "Navnet er allerede taget — prøv et andet");
        nameAvailable = false;
        proceedBtn.disabled = true;
      }
    } catch {
      setStatus("error", "!", "Kunne ikke tjekke — prøv igen");
      nameAvailable = false;
      proceedBtn.disabled = true;
    }
  }

  nameInput.addEventListener("input", () => {
    const val = nameInput.value.toLowerCase().replace(/[^a-z0-9_-]/g, "");
    if (nameInput.value !== val) nameInput.value = val;
    clearTimeout(checkTimeout);
    if (!val) { clearStatus(); return; }
    checkTimeout = setTimeout(() => checkAvailability(val), 500);
  });

  proceedBtn.addEventListener("click", () => {
    if (!nameAvailable) return;
    confirmedName = nameInput.value.trim();
    confirmedNameEl.textContent = `✓ ${confirmedName}@nostr.dk er ledigt`;
    step1.style.display = "none";
    step2.style.display = "block";
  });

  backBtn.addEventListener("click", () => {
    step2.style.display = "none";
    step1.style.display = "block";
  });

  // Pubkey validering — live feedback
  pubkeyInput.addEventListener("input", function () {
    const val = this.value.trim();
    if (!val) {
      pubkeyStatus.className = "status";
      pubkeyStatus.textContent = "";
      pubkeyInput.style.borderColor = "rgba(255,255,255,0.1)";
      payBtn.disabled = true;
      return;
    }
    if (validatePubkey(val)) {
      pubkeyStatus.className = "status available";
      pubkeyStatus.textContent = "✓ Gyldig public key";
      pubkeyInput.style.borderColor = "#4caf50";
      payBtn.disabled = false;
    } else {
      pubkeyStatus.className = "status taken";
      pubkeyStatus.textContent = "✗ Skal være npub1… (63 tegn) eller hex (64 tegn)";
      pubkeyInput.style.borderColor = "#e05050";
      payBtn.disabled = true;
    }
  });

  payBtn.addEventListener("click", async () => {
    const pubkey = pubkeyInput.value.trim();
    if (!validatePubkey(pubkey)) return;

    payBtn.disabled = true;
    payBtn.textContent = "Opretter betaling…";
    payStatus.className = "status checking";
    payStatus.textContent = "… Forbinder til BTCPay…";

    try {
      const res = await fetch("/.netlify/functions/create-nip05-invoice", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name: confirmedName, pubkey }),
      });
      const data = await res.json();
      if (data.checkoutLink) {
        window.location.href = data.checkoutLink;
      } else {
        throw new Error("Intet checkout link");
      }
    } catch {
      payStatus.className = "status error";
      payStatus.textContent = "! Noget gik galt — prøv igen";
      payBtn.disabled = false;
      payBtn.textContent = "Gå til betaling ⚡";
    }
  });
</script>