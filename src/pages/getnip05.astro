---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Få din NIP-05 identitet | nostr.dk"
  description="Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-identitet."
>
  <div class="page-header">
    <h1>Få din Nostr-identitet</h1>
    <p>
      Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-profil.
    </p>
  </div>

  <div class="register-wrap">
    <!-- Profil teaser -->
    <div class="nip05-teaser">
      <p class="nip05-teaser-label">Allerede verificeret med @nostr.dk</p>
      <div class="nip05-teaser-grid" id="teaserGrid"></div>
    </div>

    <!-- Trin 1: Tjek navn -->
    <div id="step1" class="register-form">
      <div class="field">
        <label for="name">Vælg din nostr adresse</label>
        <div class="nip05-name-row" id="nameRow">
          <input
            type="text"
            id="name"
            placeholder="ditnavn"
            autocomplete="off"
            autocapitalize="none"
            spellcheck="false"
          />
          <span class="nip05-suffix">@nostr.dk</span>
        </div>
        <div class="status" id="nameStatus"></div>
      </div>

      <p class="price-note">
        @nostr.dk NIP-05 adresse for kun <strong>2.100 sats</strong> via
        <a
          href="https://enogtyve.org/da/laer-mere/lightning/"
          target="_blank"
          rel="noopener noreferrer">Lightning</a
        > ⚡
      </p>

      <button
        id="proceedBtn"
        class="cta"
        disabled
        data-umami-event="nip05-næste"
        style="margin-top: 20px; width: 100%;">Næste</button
      >
    </div>

    <!-- Trin 2: Navn er ledigt - vis vejledning -->
    <div id="step2" class="register-form" style="display: none;">
      <div class="confirmed-name" id="confirmedName"></div>
      <div class="instructions">
        <p>Udfyld felterne i betalingsformularen som åbner i et nyt vindue:</p>
        <ol>
          <li>
            Skriv <strong id="nameReminder"></strong> i feltet
            <em>"Din nostr adresse @nostr.dk"</em> — kun navnet, ikke @nostr.dk
          </li>
          <li>Indsæt din Nostr public key (npub1… eller hex)</li>
          <li>Betal 2.100 sats via Lightning</li>
        </ol>
      </div>
      <button
        id="payBtn"
        class="cta"
        data-umami-event="nip05-betal"
        style="margin-top: 20px; width: 100%;">Gå til betaling ⚡</button
      >
      <button id="backBtn" class="back-btn">← Vælg et andet navn</button>
    </div>
  </div>
</NostrLayout>

<style>
  .register-wrap {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 80px;
  }

  /* ---- Profil teaser ---- */
  .nip05-teaser {
    margin: 0 0 30px;
  }

  .nip05-teaser-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .nip05-teaser-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 10px;
    align-items: flex-start;
  }

  .teaser-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    flex: 0 0 72px;
  }

  .teaser-col.staggered {
    margin-top: 36px;
  }

  .teaser-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(108, 79, 150, 0.5);
    display: block;
  }

  .teaser-avatar-placeholder {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid rgba(108, 79, 150, 0.3);
    background: linear-gradient(
      135deg,
      rgba(108, 79, 150, 0.2),
      rgba(55, 26, 118, 0.2)
    );
    display: block;
  }

  /* ---- Formular ---- */
  .register-form {
    text-align: left;
  }

  .field {
    margin-bottom: 1.4rem;
  }

  label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #e0e0e0;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nip05-name-row {
    display: flex;
    align-items: stretch;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .nip05-name-row:focus-within {
    border-color: rgba(108, 79, 150, 0.8);
  }

  .nip05-name-row.valid {
    border-color: #4caf50;
  }

  .nip05-name-row.taken {
    border-color: #e05050;
  }

  .nip05-name-row input[type="text"] {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 0.7rem 0.9rem;
  }

  .nip05-suffix {
    padding: 0 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
    white-space: nowrap;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
  }

  .status {
    font-size: 0.82rem;
    margin-top: 0.4rem;
    min-height: 1.1em;
  }

  .status.checking {
    color: rgba(255, 255, 255, 0.4);
  }
  .status.available {
    color: #4caf50;
  }
  .status.taken {
    color: #e05050;
  }
  .status.error {
    color: #e08050;
  }

  .price-note {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0.5rem 0 0;
  }

  .price-note strong {
    color: #fff;
  }

  .price-note a {
    color: rgba(255, 255, 255, 0.6);
  }

  .cta:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  .confirmed-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #4caf50;
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .instructions {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem 1.2rem;
    margin-bottom: 0.5rem;
  }

  .instructions p {
    font-size: 0.9rem;
    color: #e0e0e0;
    margin-bottom: 0.8rem;
  }

  .instructions ol {
    padding-left: 1.2rem;
    color: #d0d0d0;
    font-size: 0.88rem;
    line-height: 1.8;
  }

  .instructions strong {
    color: #fff;
  }

  .instructions em {
    color: rgba(255, 255, 255, 0.6);
    font-style: normal;
  }

  .back-btn {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.82rem;
    cursor: pointer;
    margin-top: 1rem;
    padding: 0;
    display: block;
    transition: color 0.2s;
  }

  .back-btn:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .register-wrap {
      padding: 0 0 40px;
    }
  }
</style>

<script>
  const BTCPAY_FORM_URL =
    "https://btcpay.ideasarelikeflames.org/forms/322ff6ea-8e6b-448f-85f8-ddb5bc5687b6";

  const nameInput = document.getElementById("name") as HTMLInputElement;
  const nameRow = document.getElementById("nameRow")!;
  const nameStatus = document.getElementById("nameStatus")!;
  const proceedBtn = document.getElementById("proceedBtn") as HTMLButtonElement;
  const step1 = document.getElementById("step1")!;
  const step2 = document.getElementById("step2")!;
  const confirmedName = document.getElementById("confirmedName")!;
  const nameReminder = document.getElementById("nameReminder")!;
  const payBtn = document.getElementById("payBtn") as HTMLButtonElement;
  const backBtn = document.getElementById("backBtn")!;

  let nameAvailable = false;
  let checkTimeout: ReturnType<typeof setTimeout>;

  // Profil teaser
  (async function loadTeaser() {
    try {
      const res = await fetch("/.well-known/nostr.json");
      const data = await res.json();
      const names = data.names || {};
      const entries = Object.entries(names)
        .sort(() => Math.random() - 0.5)
        .slice(0, 11);

      const pubkeys = entries.map(([, pubkey]) => pubkey as string);
      const teaserGrid = document.getElementById("teaserGrid")!;

      const placeholders: Record<string, HTMLElement> = {};
      const CARDS_PER_COL = 2;
      let colIndex = 0;
      let col: HTMLDivElement | null = null;
      let cardsInCol = 0;

      for (const [, pubkey] of entries) {
        if (!col || cardsInCol >= CARDS_PER_COL) {
          col = document.createElement("div");
          col.className =
            "teaser-col" + (colIndex % 2 === 1 ? " staggered" : "");
          teaserGrid.appendChild(col);
          colIndex++;
          cardsInCol = 0;
        }
        const div = document.createElement("div");
        div.className = "teaser-avatar-placeholder";
        div.style.width = "64px";
        div.style.height = "64px";
        div.style.borderRadius = "50%";
        col.appendChild(div);
        placeholders[pubkey as string] = div;
        cardsInCol++;
      }

      const profileRes = await fetch(
        `/.netlify/functions/nostr-profiles?pubkeys=${pubkeys.join(",")}`,
      );
      const profiles = await profileRes.json();

      for (const [pubkey, profile] of Object.entries(profiles) as [
        string,
        any,
      ][]) {
        if (!profile.picture) continue;
        const placeholder = placeholders[pubkey];
        if (!placeholder) continue;

        const img = document.createElement("img");
        img.className = "teaser-avatar";
        img.style.width = "64px";
        img.style.height = "64px";
        img.style.borderRadius = "50%";
        img.style.objectFit = "cover";
        img.style.border = "2px solid rgba(108, 79, 150, 0.6)";
        img.style.display = "block";
        img.src = profile.picture;
        img.alt = "";
        img.loading = "lazy";
        img.onerror = () => {};
        placeholder.replaceWith(img);
      }
    } catch {}
  })();

  function setStatus(type: string, icon: string, text: string) {
    nameStatus.className = `status ${type}`;
    nameStatus.textContent = `${icon} ${text}`;
    nameRow.className =
      "nip05-name-row " +
      (type === "available" ? "valid" : type === "taken" ? "taken" : "");
  }

  function clearStatus() {
    nameStatus.className = "status";
    nameStatus.textContent = "";
    nameRow.className = "nip05-name-row";
    nameAvailable = false;
    proceedBtn.disabled = true;
  }

  async function checkAvailability(name: string) {
    if (!name) {
      clearStatus();
      return;
    }

    if (!/^[a-z0-9_-]+$/.test(name)) {
      setStatus("taken", "✗", "Kun små bogstaver, tal, _ og - er tilladt");
      nameAvailable = false;
      proceedBtn.disabled = true;
      return;
    }

    setStatus("checking", "…", "Tjekker tilgængelighed…");

    try {
      const res = await fetch(
        `/.netlify/functions/check-name?name=${encodeURIComponent(name)}`,
      );
      const data = await res.json();

      if (data.available) {
        setStatus("available", "✓", "Ledigt!");
        nameAvailable = true;
        proceedBtn.disabled = false;
      } else {
        setStatus("taken", "✗", "Navnet er allerede taget — prøv et andet");
        nameAvailable = false;
        proceedBtn.disabled = true;
      }
    } catch {
      setStatus("error", "!", "Kunne ikke tjekke — prøv igen");
      nameAvailable = false;
      proceedBtn.disabled = true;
    }
  }

  nameInput.addEventListener("input", () => {
    const val = nameInput.value.toLowerCase().replace(/[^a-z0-9_-]/g, "");
    if (nameInput.value !== val) nameInput.value = val;

    clearTimeout(checkTimeout);
    if (!val) {
      clearStatus();
      return;
    }

    checkTimeout = setTimeout(() => checkAvailability(val), 500);
  });

  proceedBtn.addEventListener("click", () => {
    if (!nameAvailable) return;
    const name = nameInput.value.trim();

    confirmedName.textContent = `✓ ${name}@nostr.dk er ledigt`;
    nameReminder.textContent = name;
    payBtn.onclick = () => {
      window.open(
        BTCPAY_FORM_URL,
        "btcpay",
        "width=600,height=700,resizable=yes",
      );
    };

    step1.style.display = "none";
    step2.style.display = "block";
  });

  backBtn.addEventListener("click", () => {
    step2.style.display = "none";
    step1.style.display = "block";
  });
</script>
