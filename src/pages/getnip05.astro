---
import NostrLayout from "../layouts/NostrLayout.astro";
---

<NostrLayout
  title="Få din NIP-05 identitet | nostr.dk"
  description="Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-identitet."
>

  <div class="page-header">
    <h1>Få din Nostr-identitet</h1>
    <p>Registrer en NIP-05 adresse på nostr.dk og verificer din Nostr-profil.</p>
  </div>

  <div class="register-wrap">
    <div class="card register-card">

      <!-- Trin 1: Tjek navn -->
      <div id="step1">
        <div class="field">
          <label for="name">Vælg din nostr adresse</label>
          <div class="name-row" id="nameRow">
            <input
              type="text"
              id="name"
              placeholder="alice"
              autocomplete="off"
              autocapitalize="none"
              spellcheck="false"
            />
            <span class="name-suffix">@nostr.dk</span>
          </div>
          <div class="status" id="nameStatus"></div>
        </div>

        <p class="price-note">Engangsgebyr: <strong>2100 sats</strong> via Lightning ⚡</p>

        <button id="proceedBtn" class="cta" disabled style="margin-top: 20px;">Fortsæt til betaling</button>
      </div>

      <!-- Trin 2: Navn er ledigt - vis vejledning -->
      <div id="step2" style="display: none;">
        <div class="confirmed-name" id="confirmedName"></div>

        <div class="instructions">
          <p>Dit navn er ledigt! Udfyld nu felterne i betalingsformularen:</p>
          <ol>
            <li>Skriv <strong id="nameReminder"></strong> i feltet <em>"Din nostr adresse"</em></li>
            <li>Indsæt din Nostr public key (npub1… eller hex) i det andet felt</li>
            <li>Betal 2100 sats via Lightning</li>
          </ol>
        </div>

        <a id="btcpayLink" href="#" class="cta" style="margin-top: 20px; text-align: center;">Gå til betaling ⚡</a>

        <button id="backBtn" class="back-btn">← Vælg et andet navn</button>
      </div>

    </div>
  </div>

</NostrLayout>

<style>
  .register-wrap {
    display: flex;
    justify-content: center;
    padding: 0 0 60px;
  }

  .register-card {
    width: 100%;
    max-width: 480px;
    transition: none;
  }

  .register-card:hover {
    transform: none;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  .field {
    margin-bottom: 1.4rem;
  }

  label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #e0e0e0;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .name-row {
    display: flex;
    align-items: stretch;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .name-row:focus-within {
    border-color: rgba(108, 79, 150, 0.8);
  }

  .name-row.valid {
    border-color: #4caf50;
  }

  .name-row.taken {
    border-color: #e05050;
  }

  .name-row input[type="text"] {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 0.7rem 0.9rem;
  }

  .name-suffix {
    padding: 0 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
    white-space: nowrap;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
  }

  .status {
    font-size: 0.82rem;
    margin-top: 0.4rem;
    min-height: 1.1em;
  }

  .status.checking  { color: rgba(255, 255, 255, 0.4); }
  .status.available { color: #4caf50; }
  .status.taken     { color: #e05050; }
  .status.error     { color: #e08050; }

  .price-note {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0.5rem 0 0;
  }

  .price-note strong {
    color: #fff;
  }

  .cta:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  .confirmed-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #4caf50;
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .instructions {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem 1.2rem;
    margin-bottom: 0.5rem;
  }

  .instructions p {
    font-size: 0.9rem;
    color: #e0e0e0;
    margin-bottom: 0.8rem;
  }

  .instructions ol {
    padding-left: 1.2rem;
    color: #d0d0d0;
    font-size: 0.88rem;
    line-height: 1.8;
  }

  .instructions strong {
    color: #fff;
  }

  .instructions em {
    color: rgba(255, 255, 255, 0.6);
    font-style: normal;
  }

  .back-btn {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.82rem;
    cursor: pointer;
    margin-top: 1rem;
    padding: 0;
    display: block;
    transition: color 0.2s;
  }

  .back-btn:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .register-wrap {
      padding: 0 0 40px;
    }
  }
</style>

<script>
  const BTCPAY_FORM_URL = "https://btcpay.ideasarelikeflames.org/forms/322ff6ea-8e6b-448f-85f8-ddb5bc5687b6";

  const nameInput     = document.getElementById("name") as HTMLInputElement;
  const nameRow       = document.getElementById("nameRow")!;
  const nameStatus    = document.getElementById("nameStatus")!;
  const proceedBtn    = document.getElementById("proceedBtn") as HTMLButtonElement;
  const step1         = document.getElementById("step1")!;
  const step2         = document.getElementById("step2")!;
  const confirmedName = document.getElementById("confirmedName")!;
  const nameReminder  = document.getElementById("nameReminder")!;
  const btcpayLink    = document.getElementById("btcpayLink") as HTMLAnchorElement;
  const backBtn       = document.getElementById("backBtn")!;

  let nameAvailable = false;
  let checkTimeout: ReturnType<typeof setTimeout>;

  function setStatus(type: string, icon: string, text: string) {
    nameStatus.className = `status ${type}`;
    nameStatus.textContent = `${icon} ${text}`;
    nameRow.className = "name-row " + (type === "available" ? "valid" : type === "taken" ? "taken" : "");
  }

  function clearStatus() {
    nameStatus.className = "status";
    nameStatus.textContent = "";
    nameRow.className = "name-row";
    nameAvailable = false;
    proceedBtn.disabled = true;
  }

  async function checkAvailability(name: string) {
    if (!name) { clearStatus(); return; }

    if (!/^[a-z0-9_-]+$/.test(name)) {
      setStatus("taken", "✗", "Kun små bogstaver, tal, _ og - er tilladt");
      nameAvailable = false;
      proceedBtn.disabled = true;
      return;
    }

    setStatus("checking", "…", "Tjekker tilgængelighed…");

    try {
      const res = await fetch(`/.netlify/functions/check-name?name=${encodeURIComponent(name)}`);
      const data = await res.json();

      if (data.available) {
        setStatus("available", "✓", "Ledigt!");
        nameAvailable = true;
        proceedBtn.disabled = false;
      } else {
        setStatus("taken", "✗", "Navnet er allerede taget — prøv et andet");
        nameAvailable = false;
        proceedBtn.disabled = true;
      }
    } catch {
      setStatus("error", "!", "Kunne ikke tjekke — prøv igen");
      nameAvailable = false;
      proceedBtn.disabled = true;
    }
  }

  nameInput.addEventListener("input", () => {
    const val = nameInput.value.toLowerCase().replace(/[^a-z0-9_-]/g, "");
    if (nameInput.value !== val) nameInput.value = val;

    clearTimeout(checkTimeout);
    if (!val) { clearStatus(); return; }

    checkTimeout = setTimeout(() => checkAvailability(val), 500);
  });

  proceedBtn.addEventListener("click", () => {
    if (!nameAvailable) return;
    const name = nameInput.value.trim();

    // Vis trin 2 med vejledning
    confirmedName.textContent = `✓ ${name}@nostr.dk er ledigt`;
    nameReminder.textContent = name;
    btcpayLink.href = BTCPAY_FORM_URL;

    step1.style.display = "none";
    step2.style.display = "block";
  });

  backBtn.addEventListener("click", () => {
    step2.style.display = "none";
    step1.style.display = "block";
  });
</script>