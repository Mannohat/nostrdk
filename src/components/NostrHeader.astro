---
// Nostr.dk Header
---

<header>
  <div class="logo-container">
    <a href="/" class="logo-link">
      <img src="/NOSTRDK_26.png" alt="Nostr Logo" id="logo" />
    </a>
  </div>
  
  <nav>
    <ul>
      <li><a href="/">Hjem</a></li>
      <li><a href="/#nostr-ressourcer">Ressourcer</a></li>
      <li><a href="/#nostr-nip05">Nostr Adresse</a></li>
      <li><a href="/podcasts">Podcasts</a></li>
      <li><a href="/apps">Apps & Tjenester</a></li>
      <li><a href="/#nostr-om">Om</a></li>
      <li><a href="/#nostr-support">Support</a></li>
    </ul>
  </nav>

  <div class="burger-menu" id="burger-menu" aria-expanded="false">
    <div></div>
    <div></div>
    <div></div>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <a href="/">Hjem</a>
  <a href="/#nostr-ressourcer">Ressourcer</a>
  <a href="/#nostr-nip05">Nostr Adresse</a>
  <a href="/#nostr-om">Om</a>
  <a href="/podcasts">Podcasts</a>
  <a href="/apps">Apps & Tjenester</a>
</div>

<style>
header {
  background: #1F1D2B;
  background: radial-gradient(ellipse 40% 100% at 5% center, #3d2d6e 0%, #1F1D2B 55%);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: #FFF;
  padding: 20px 40px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 1000;
  border-bottom: 1px solid rgba(160, 132, 202, 0.2);
}

.logo-container {
  display: flex;
  align-items: center;
}

.logo-link {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  transition: opacity 0.3s;
}

.logo-link:hover {
  opacity: 0.8;
}

.logo-container img {
  height: auto;
  max-height: 60px;
  border-radius: 8px;
  box-shadow: 0 2px 12px rgba(55, 26, 118, 0.4);
  transition: transform 0.5s ease, box-shadow 0.3s ease;
}

.logo-container img:hover {
  box-shadow: 0 4px 20px rgba(108, 79, 150, 0.6);
}

nav ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  gap: 25px;
}

nav ul li a {
  color: #FFF;
  font-size: 16px;
  font-weight: 600;
  transition: color 0.3s;
}

nav ul li a:hover {
  color: #A084CA;
}

.burger-menu {
  display: none;
  flex-direction: column;
  justify-content: space-between;
  width: 30px;
  height: 20px;
  cursor: pointer;
}

.burger-menu div {
  background-color: #FFF;
  height: 3px;
  width: 100%;
  transition: all 0.3s;
}

.mobile-menu {
  display: none;
  flex-direction: column;
  position: fixed;
  top: 70px;
  right: 0;
  background: linear-gradient(180deg, #1F1D2B, #29273C);
  border-top: 1px solid rgba(160, 132, 202, 0.2);
  width: 100%;
  text-align: center;
  padding: 20px;
  z-index: 1000;
}

.mobile-menu a {
  padding: 10px;
  color: #FFF;
  font-size: 18px;
  border-bottom: 1px solid rgba(160, 132, 202, 0.15);
  transition: color 0.3s;
}

.mobile-menu a:hover {
  color: #A084CA;
}

.mobile-menu.active {
  display: flex;
}

@media (max-width: 768px) {
  .logo-container img {
    max-height: 50px;
  }

  nav {
    display: none;
  }

  .burger-menu {
    display: flex;
  }

  header {
    padding: 16px 20px;
  }
}
</style>

<script>
  const burgerMenu = document.getElementById('burger-menu');
  const mobileMenu = document.getElementById('mobile-menu');

  if (burgerMenu && mobileMenu) {
    burgerMenu.addEventListener('click', () => {
      const expanded = burgerMenu.getAttribute('aria-expanded') === 'true';
      burgerMenu.setAttribute('aria-expanded', !expanded);
      mobileMenu.setAttribute('aria-hidden', expanded);
      mobileMenu.classList.toggle('active');
    });
  }

  function setupSmoothScroll() {
    const headerHeight = 80;
    document.querySelectorAll('a[href^="/#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (window.location.pathname === '/') {
          e.preventDefault();
          const targetId = href.substring(2);
          if (targetId === 'top') {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          } else {
            const targetElement = document.getElementById(targetId);
            if (targetElement) {
              const offset = targetElement.getBoundingClientRect().top + window.scrollY - headerHeight;
              window.scrollTo({ top: offset, behavior: 'smooth' });
              if (mobileMenu && mobileMenu.classList.contains('active')) {
                mobileMenu.classList.remove('active');
                burgerMenu.setAttribute('aria-expanded', 'false');
              }
            }
          }
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', setupSmoothScroll);
  document.addEventListener('astro:page-load', setupSmoothScroll);
</script>
